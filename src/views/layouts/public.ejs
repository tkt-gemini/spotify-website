<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Spotify Clone - Listen for Free</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            spotify: {
              DEFAULT: '#1DB954',
              dark: '#1ed760',
              base: '#121212',
              highlight: '#1a1a1a',
              press: '#000000',
              elevated: '#242424'
            }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-black text-white h-screen flex flex-col font-sans">
  <!-- Top Navbar -->
  <header class="h-16 bg-black/90 flex items-center justify-between px-6 sticky top-0 z-50">
    <div class="flex items-center gap-4">
      <div class="text-white font-bold text-xl flex items-center gap-2">
        <svg viewBox="0 0 24 24" class="h-8 w-8 fill-current text-white"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.6.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
        Spotify
      </div>
    </div>
    <div class="flex items-center gap-4">
      <% if (locals.isLogged) { %>
        <a href="/app/home" class="bg-white text-black font-bold px-6 py-2 rounded-full hover:scale-105 transition">Go to App</a>
      <% } else { %>
        <a href="/register" class="text-gray-300 font-bold hover:text-white hover:scale-105 transition">Sign up</a>
        <a href="/login" class="bg-white text-black font-bold px-6 py-2 rounded-full hover:scale-105 transition">Log in</a>
      <% } %>
    </div>
  </header>

  <!-- Main Content -->
  <main class="flex-1 overflow-y-auto bg-gradient-to-b from-[#1f1f1f] to-[#121212] p-6 pb-24">
    <%- body %>
  </main>

  <!-- Simple Public Player -->
  <div class="h-20 bg-black border-t border-gray-800 flex items-center justify-between px-4 fixed bottom-0 w-full z-50">
    <div class="flex items-center w-1/3">
      <img id="public-player-cover" src="/images/default-cover.png" class="h-14 w-14 rounded object-cover hidden">
      <div class="ml-4 hidden" id="public-player-info">
        <div id="public-player-title" class="text-white text-sm font-semibold"></div>
        <div id="public-player-artist" class="text-gray-400 text-xs"></div>
      </div>
    </div>
    <div class="flex flex-col items-center w-1/3">
      <div class="flex items-center gap-4">
        <button id="public-btn-play-pause" class="w-8 h-8 flex items-center justify-center bg-white rounded-full hover:scale-105 disabled:opacity-50 text-black">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        </button>
      </div>
      <div class="w-full mt-2 flex items-center gap-2 text-xs text-gray-400">
        <span id="public-time-current">0:00</span>
        <div class="flex-1 h-1 bg-gray-600 rounded-full relative">
          <div id="public-progress-bar" class="h-full bg-white rounded-full" style="width: 0%"></div>
        </div>
        <span id="public-time-total">0:00</span>
      </div>
    </div>
    <div class="flex items-center justify-end w-1/3 text-gray-400 text-xs">
      Preview Mode
    </div>
  </div>

  <audio id="public-audio-element"></audio>
  <script src="/js/public-player.js"></script>
</body>
</html>
