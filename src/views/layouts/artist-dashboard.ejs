<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof currentArtist !== 'undefined' ? currentArtist.name : 'Artist' %> - Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-black text-white h-screen flex flex-col overflow-hidden">
  <div class="flex-1 flex overflow-hidden">
    <!-- Sidebar -->
    <div class="w-64 bg-black flex flex-col p-4 gap-4 border-r border-zinc-800">
      <div class="flex items-center gap-2 mb-6">
        <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 14.5c-2.49 0-4.5-2.01-4.5-4.5S9.51 7.5 12 7.5s4.5 2.01 4.5 4.5-2.01 4.5-4.5 4.5zm0-7.5c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
        </svg>
        <span class="font-bold text-xl tracking-tight">Artist Dashboard</span>
      </div>
      
      <nav class="flex flex-col gap-2 flex-1">
        <a href="/artist/<%= currentArtist.id %>/overview" class="flex items-center gap-4 text-sm font-bold p-2 <%= typeof activeTab !== 'undefined' && activeTab === 'overview' ? 'text-white bg-zinc-800 rounded' : 'text-zinc-400 hover:text-white' %> transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
          Overview
        </a>
        <a href="/artist/<%= currentArtist.id %>/tracks" class="flex items-center gap-4 text-sm font-bold p-2 <%= typeof activeTab !== 'undefined' && activeTab === 'tracks' ? 'text-white bg-zinc-800 rounded' : 'text-zinc-400 hover:text-white' %> transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path></svg>
          Tracks
        </a>
        <a href="/artist/<%= currentArtist.id %>/albums" class="flex items-center gap-4 text-sm font-bold p-2 <%= activeTab === 'albums' ? 'text-white bg-zinc-800 rounded' : 'text-zinc-400 hover:text-white' %> transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
          Albums
        </a>
        <a href="/artist/<%= currentArtist.id %>/analytics" class="flex items-center gap-4 text-sm font-bold p-2 <%= typeof activeTab !== 'undefined' && activeTab === 'analytics' ? 'text-white bg-zinc-800 rounded' : 'text-zinc-400 hover:text-white' %> transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
          Analytics
        </a>
        <a href="#" class="flex items-center gap-4 text-sm font-bold p-2 text-zinc-400 hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
          Profile
        </a>
      </nav>

      <!-- Back to User App -->
      <a href="/app/home" class="flex items-center gap-4 text-sm font-bold p-2 text-zinc-400 hover:text-white transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to App
      </a>
    </div>
    
    <!-- Main Area -->
    <div class="flex-1 flex flex-col overflow-hidden bg-zinc-900 rounded-lg m-2">
      <!-- Topbar -->
      <header class="h-16 flex items-center justify-between px-6 sticky top-0 bg-zinc-900 z-10 border-b border-zinc-800">
        <div class="flex items-center gap-4">
          <% if (currentArtist.avatarUrl) { %>
            <img src="<%= currentArtist.avatarUrl %>" class="w-8 h-8 rounded-full object-cover">
          <% } else { %>
            <div class="w-8 h-8 rounded-full bg-zinc-700 flex items-center justify-center">
              <svg class="w-4 h-4 text-zinc-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
            </div>
          <% } %>
          <span class="font-bold"><%= currentArtist.name %></span>
          <span class="text-xs bg-zinc-800 text-zinc-400 px-2 py-1 rounded uppercase"><%= artistRole %></span>
        </div>
        
        <div class="flex items-center gap-4 group relative">
          <button class="flex items-center gap-2 hover:bg-zinc-800 p-2 rounded-full transition-colors">
            <div class="w-8 h-8 rounded-full bg-zinc-700 flex items-center justify-center">
              <span class="font-bold text-sm"><%= currentUser ? currentUser.name.charAt(0) : 'U' %></span>
            </div>
            <span class="text-sm font-bold hidden md:block"><%= currentUser ? currentUser.name : 'User' %></span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          
          <div class="absolute right-0 top-full mt-2 w-48 bg-zinc-800 rounded shadow-xl hidden group-hover:block p-1">
            <a href="/artist/select" class="block px-4 py-2 text-sm text-zinc-200 hover:bg-zinc-700 rounded">Switch Artist</a>
            <form action="/logout" method="POST" class="m-0 border-t border-zinc-700 mt-1 pt-1">
              <button type="submit" class="w-full text-left px-4 py-2 text-sm text-zinc-200 hover:bg-zinc-700 rounded">Log out</button>
            </form>
          </div>
        </div>
      </header>
      
      <!-- Main Content -->
      <main class="flex-1 overflow-y-auto p-8 relative">
        <%- body %>
      </main>
    </div>
  </div>
</body>
</html>
