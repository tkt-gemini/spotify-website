<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Optional Chart.js if we put charts in admin later -->
</head>
<body class="bg-black text-white h-screen flex flex-col overflow-hidden">
  <div class="flex-1 flex overflow-hidden">
    <!-- Sidebar -->
    <div class="w-64 bg-black flex flex-col p-4 gap-4 border-r border-zinc-800">
      <div class="flex items-center gap-2 mb-6">
        <svg class="w-8 h-8 text-red-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zm0 7.5L5.5 6.5 12 4.5l6.5 2L12 9.5zM2 12l10 5 10-5M2 17l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
        <span class="font-bold text-xl tracking-tight">Admin Center</span>
      </div>
      
      <nav class="flex flex-col gap-2 flex-1">
        <a href="/admin" class="flex items-center gap-4 text-sm font-bold p-2 text-zinc-400 hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
          Dashboard
        </a>
        <a href="/admin/users" class="flex items-center gap-4 text-sm font-bold p-2 text-zinc-400 hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
          Users
        </a>
        <a href="/admin/tracks" class="flex items-center gap-4 text-sm font-bold p-2 text-zinc-400 hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path></svg>
          Tracks
        </a>
        <a href="/admin/podcasts" class="flex items-center gap-4 text-sm font-bold p-2 text-zinc-400 hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
          Podcasts
        </a>
      </nav>

      <!-- Back to User App -->
      <a href="/app/home" class="flex items-center gap-4 text-sm font-bold p-2 text-zinc-400 hover:text-white transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to App
      </a>
    </div>
    
    <!-- Main Area -->
    <div class="flex-1 flex flex-col overflow-hidden bg-zinc-900 rounded-lg m-2">
      <!-- Topbar -->
      <header class="h-16 flex items-center justify-between px-6 sticky top-0 bg-zinc-900 z-10 border-b border-zinc-800">
        <div class="flex items-center gap-4">
        </div>
        
        <div class="flex items-center gap-4 group relative">
          <button class="flex items-center gap-2 hover:bg-zinc-800 p-2 rounded-full transition-colors">
            <div class="w-8 h-8 rounded-full bg-red-600 flex items-center justify-center">
              <span class="font-bold text-sm"><%= currentUser ? currentUser.name.charAt(0) : 'A' %></span>
            </div>
            <span class="text-sm font-bold hidden md:block"><%= currentUser ? currentUser.name : 'Admin' %></span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          
          <div class="absolute right-0 top-full mt-2 w-48 bg-zinc-800 rounded shadow-xl hidden group-hover:block p-1">
            <form action="/logout" method="POST" class="m-0 border-t border-zinc-700 mt-1 pt-1">
              <button type="submit" class="w-full text-left px-4 py-2 text-sm text-zinc-200 hover:bg-zinc-700 rounded">Log out</button>
            </form>
          </div>
        </div>
      </header>
      
      <!-- Main Content -->
      <main class="flex-1 overflow-y-auto p-8 relative">
        <%- body %>
      </main>
    </div>
  </div>
</body>
</html>
