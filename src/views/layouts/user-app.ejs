<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Spotify Clone</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-black text-white h-screen flex flex-col overflow-hidden">
  <div class="flex-1 flex overflow-hidden">
    <!-- Sidebar -->
    <%- include('../partials/user-sidebar') %>
    
    <!-- Main Area -->
    <div class="flex-1 flex flex-col overflow-hidden bg-zinc-900 rounded-lg m-2">
      <!-- Topbar -->
      <%- include('../partials/top-bar') %>
      
      <!-- Main Content -->
      <main class="flex-1 overflow-y-auto p-6">
        <%- body %>
      </main>
    </div>
  </div>

  <!-- Bottom Player -->
  <%- include('../partials/bottom-player') %>
  
  <!-- Global Scripts -->
  <script type="module" src="/js/library-actions.js"></script>
  <script type="module" src="/js/player.js"></script>
</body>
</html>
