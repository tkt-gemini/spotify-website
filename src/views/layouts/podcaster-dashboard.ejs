<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof currentShow !== 'undefined' ? currentShow.title : 'Podcast' %> - Podcaster Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-black text-white h-screen flex flex-col overflow-hidden">
  <div class="flex-1 flex overflow-hidden">
    <!-- Sidebar -->
    <div class="w-64 bg-black flex flex-col p-4 gap-4 border-r border-zinc-800">
      <div class="flex items-center gap-2 mb-6">
        <svg class="w-8 h-8 text-purple-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2a10 10 0 00-3.83 19.24A10 10 0 0012 22a10 10 0 000-20zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/><path d="M11 6h2v4h-2zm0 6h2v6h-2z"/></svg>
        <span class="font-bold text-xl tracking-tight">Podcaster</span>
      </div>
      
      <nav class="flex flex-col gap-2 flex-1">
        <% if (typeof currentShow !== 'undefined' && currentShow) { %>
          <a href="/podcaster/shows/<%= currentShow.id %>" class="flex items-center gap-4 text-sm font-bold p-2 text-zinc-400 hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
            Overview
          </a>
          <a href="/podcaster/shows/<%= currentShow.id %>/episodes" class="flex items-center gap-4 text-sm font-bold p-2 text-zinc-400 hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            Episodes
          </a>
        <% } %>
        <a href="/podcaster/shows" class="flex items-center gap-4 text-sm font-bold p-2 text-zinc-400 hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
          Switch Show
        </a>
      </nav>

      <!-- Back to User App -->
      <a href="/app/home" class="flex items-center gap-4 text-sm font-bold p-2 text-zinc-400 hover:text-white transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        Back to App
      </a>
    </div>
    
    <!-- Main Area -->
    <div class="flex-1 flex flex-col overflow-hidden bg-zinc-900 rounded-lg m-2">
      <!-- Topbar -->
      <header class="h-16 flex items-center justify-between px-6 sticky top-0 bg-zinc-900 z-10 border-b border-zinc-800">
        <div class="flex items-center gap-4">
          <% if (typeof currentShow !== 'undefined' && currentShow) { %>
            <% if (currentShow.coverUrl) { %>
              <img src="<%= currentShow.coverUrl %>" class="w-8 h-8 rounded object-cover">
            <% } else { %>
              <div class="w-8 h-8 rounded bg-zinc-700 flex items-center justify-center">
                <svg class="w-4 h-4 text-zinc-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
              </div>
            <% } %>
            <span class="font-bold"><%= currentShow.title %></span>
            <span class="text-xs bg-zinc-800 text-zinc-400 px-2 py-1 rounded uppercase"><%= typeof showRole !== 'undefined' ? showRole : '' %></span>
          <% } %>
        </div>
        
        <div class="flex items-center gap-4 group relative">
          <button class="flex items-center gap-2 hover:bg-zinc-800 p-2 rounded-full transition-colors">
            <div class="w-8 h-8 rounded-full bg-zinc-700 flex items-center justify-center">
              <span class="font-bold text-sm"><%= currentUser ? currentUser.name.charAt(0) : 'U' %></span>
            </div>
            <span class="text-sm font-bold hidden md:block"><%= currentUser ? currentUser.name : 'User' %></span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          
          <div class="absolute right-0 top-full mt-2 w-48 bg-zinc-800 rounded shadow-xl hidden group-hover:block p-1">
            <a href="/podcaster/shows" class="block px-4 py-2 text-sm text-zinc-200 hover:bg-zinc-700 rounded">Switch Show</a>
            <form action="/logout" method="POST" class="m-0 border-t border-zinc-700 mt-1 pt-1">
              <button type="submit" class="w-full text-left px-4 py-2 text-sm text-zinc-200 hover:bg-zinc-700 rounded">Log out</button>
            </form>
          </div>
        </div>
      </header>
      
      <!-- Main Content -->
      <main class="flex-1 overflow-y-auto p-8 relative">
        <%- body %>
      </main>
    </div>
  </div>
</body>
</html>
