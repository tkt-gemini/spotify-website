<footer class="h-24 bg-zinc-900 border-t border-zinc-800 px-4 flex items-center justify-between shrink-0">
  <!-- Track Info -->
  <div class="flex items-center gap-4 w-[30%] min-w-[180px]">
    <div id="player-cover-container" class="w-14 h-14 bg-zinc-800 rounded flex-shrink-0 flex items-center justify-center overflow-hidden">
      <!-- Default state: empty cover -->
      <svg class="w-6 h-6 text-zinc-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg>
    </div>
    <div class="flex flex-col truncate">
      <span id="player-title" class="text-sm font-bold truncate">No Track Selected</span>
      <span id="player-artist" class="text-xs text-zinc-400 truncate"></span>
    </div>
  </div>

  <!-- Player Controls -->
  <div class="flex flex-col items-center max-w-[722px] w-[40%]">
    <audio id="global-audio-player" preload="none"></audio>
    <div class="flex items-center gap-6 mb-2">
      <button class="text-zinc-400 hover:text-white transition-colors disabled:opacity-50" disabled>
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/></svg>
      </button>
      <button id="player-play-btn" class="w-8 h-8 flex items-center justify-center bg-white text-black rounded-full hover:scale-105 transition-transform disabled:opacity-50 disabled:hover:scale-100" disabled>
        <!-- Play Icon (default) -->
        <svg id="icon-play" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        <!-- Pause Icon (hidden by default) -->
        <svg id="icon-pause" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
      </button>
      <button class="text-zinc-400 hover:text-white transition-colors disabled:opacity-50" disabled>
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>
      </button>
    </div>
    <div class="w-full flex items-center gap-2">
      <span id="player-time-current" class="text-xs text-zinc-400 w-10 text-right">0:00</span>
      <div class="h-1 bg-zinc-800 rounded-full flex-1 relative group cursor-pointer" id="player-progress-bar">
        <div id="player-progress-fill" class="h-full bg-white group-hover:bg-green-500 rounded-full w-0"></div>
      </div>
      <span id="player-time-total" class="text-xs text-zinc-400 w-10">0:00</span>
    </div>
  </div>

  <!-- Extra Controls (Volume etc) -->
  <div class="flex items-center justify-end gap-4 w-[30%] min-w-[180px]">
    <svg class="w-5 h-5 text-zinc-400" fill="currentColor" viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
    <div class="w-24 h-1 bg-zinc-800 rounded-full group cursor-pointer" id="player-volume-bar">
      <div id="player-volume-fill" class="h-full bg-white group-hover:bg-green-500 rounded-full w-full"></div>
    </div>
  </div>
</footer>

<script type="module" src="/js/player.js"></script>
