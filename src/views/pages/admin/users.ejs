<div class="max-w-6xl mx-auto">
  <div class="mb-8">
    <h1 class="text-3xl font-bold">User Management</h1>
    <p class="text-zinc-400 mt-2">View and manage all registered users.</p>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-500/10 border border-red-500 text-red-500 p-4 rounded-md mb-6">
      <%= error %>
    </div>
  <% } %>

  <div class="bg-zinc-800/30 rounded-lg overflow-hidden border border-zinc-800">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-zinc-800 border-b border-zinc-700 text-zinc-400 text-sm">
          <th class="p-4 font-normal uppercase tracking-wider">ID</th>
          <th class="p-4 font-normal uppercase tracking-wider">Name / Email</th>
          <th class="p-4 font-normal uppercase tracking-wider">Joined At</th>
          <th class="p-4 font-normal uppercase tracking-wider">Default Role</th>
          <th class="p-4 font-normal uppercase tracking-wider text-right">Action</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(user => { %>
          <tr class="border-b border-zinc-800/50 hover:bg-zinc-800/50 transition-colors">
            <td class="p-4 text-zinc-500 text-sm">#<%= user.id %></td>
            <td class="p-4">
              <div class="font-bold text-white"><%= user.name %></div>
              <div class="text-sm text-zinc-400"><%= user.email %></div>
            </td>
            <td class="p-4 text-zinc-400 text-sm">
              <%= new Date(user.createdAt).toLocaleDateString() %>
            </td>
            <td class="p-4">
              <span class="px-2 py-1 bg-zinc-700 text-zinc-300 text-xs rounded uppercase font-bold">
                <%= user.defaultRole %>
              </span>
            </td>
            <td class="p-4 text-right">
              <form action="/admin/users/<%= user.id %>/default-role" method="POST" class="inline-flex items-center gap-2">
                <select name="newRole" class="bg-zinc-900 border border-zinc-700 text-sm rounded px-2 py-1 text-white focus:outline-none focus:border-white">
                  <option value="USER" <%= user.defaultRole === 'USER' ? 'selected' : '' %>>USER</option>
                  <option value="ARTIST" <%= user.defaultRole === 'ARTIST' ? 'selected' : '' %>>ARTIST</option>
                  <option value="PODCASTER" <%= user.defaultRole === 'PODCASTER' ? 'selected' : '' %>>PODCASTER</option>
                  <option value="ADMIN" <%= user.defaultRole === 'ADMIN' ? 'selected' : '' %>>ADMIN</option>
                </select>
                <button type="submit" class="bg-white text-black px-3 py-1 rounded text-sm font-bold hover:bg-zinc-200 transition-colors">
                  Save
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
