<div class="max-w-6xl mx-auto">
  <div class="mb-8">
    <h1 class="text-3xl font-bold">Podcast Management</h1>
    <p class="text-zinc-400 mt-2">View and manage all podcast shows and episodes.</p>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-500/10 border border-red-500 text-red-500 p-4 rounded-md mb-6">
      <%= error %>
    </div>
  <% } %>

  <h2 class="text-2xl font-bold mb-4">Podcast Shows</h2>
  <div class="bg-zinc-800/30 rounded-lg overflow-hidden border border-zinc-800 mb-12">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-zinc-800 border-b border-zinc-700 text-zinc-400 text-sm">
          <th class="p-4 font-normal uppercase tracking-wider">Title / Owner</th>
          <th class="p-4 font-normal uppercase tracking-wider">Created At</th>
          <th class="p-4 font-normal uppercase tracking-wider">Status</th>
          <th class="p-4 font-normal uppercase tracking-wider text-right">Action</th>
        </tr>
      </thead>
      <tbody>
        <% if (shows && shows.length > 0) { %>
          <% shows.forEach(show => { %>
            <tr class="border-b border-zinc-800/50 hover:bg-zinc-800/50 transition-colors">
              <td class="p-4">
                <div class="font-bold text-white"><%= show.title %></div>
                <div class="text-sm text-zinc-400"><%= show.owner.name %></div>
              </td>
              <td class="p-4 text-zinc-400 text-sm">
                <%= new Date(show.createdAt).toLocaleDateString() %>
              </td>
              <td class="p-4">
                <span class="px-2 py-1 bg-zinc-700 text-zinc-300 text-xs rounded uppercase font-bold">
                  <%= show.status %>
                </span>
              </td>
              <td class="p-4 text-right">
                <form action="/admin/podcasts/<%= show.id %>/status" method="POST" class="inline-flex items-center gap-2">
                  <select name="status" class="bg-zinc-900 border border-zinc-700 text-sm rounded px-2 py-1 text-white focus:outline-none focus:border-white">
                    <option value="DRAFT" <%= show.status === 'DRAFT' ? 'selected' : '' %>>DRAFT</option>
                    <option value="PUBLISHED" <%= show.status === 'PUBLISHED' ? 'selected' : '' %>>PUBLISHED</option>
                    <option value="HIDDEN" <%= show.status === 'HIDDEN' ? 'selected' : '' %>>HIDDEN</option>
                    <option value="ARCHIVED" <%= show.status === 'ARCHIVED' ? 'selected' : '' %>>ARCHIVED</option>
                    <option value="REMOVED" <%= show.status === 'REMOVED' ? 'selected' : '' %>>REMOVED</option>
                  </select>
                  <button type="submit" class="bg-white text-black px-3 py-1 rounded text-sm font-bold hover:bg-zinc-200 transition-colors">
                    Save
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="4" class="p-8 text-center text-zinc-500">No shows found.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <h2 class="text-2xl font-bold mb-4">Podcast Episodes</h2>
  <div class="bg-zinc-800/30 rounded-lg overflow-hidden border border-zinc-800">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-zinc-800 border-b border-zinc-700 text-zinc-400 text-sm">
          <th class="p-4 font-normal uppercase tracking-wider">Title / Show</th>
          <th class="p-4 font-normal uppercase tracking-wider">Audio File</th>
          <th class="p-4 font-normal uppercase tracking-wider">Published At</th>
          <th class="p-4 font-normal uppercase tracking-wider">Status</th>
          <th class="p-4 font-normal uppercase tracking-wider text-right">Action</th>
        </tr>
      </thead>
      <tbody>
        <% if (episodes && episodes.length > 0) { %>
          <% episodes.forEach(episode => { %>
            <tr class="border-b border-zinc-800/50 hover:bg-zinc-800/50 transition-colors">
              <td class="p-4">
                <div class="font-bold text-white"><%= episode.title %></div>
                <div class="text-sm text-zinc-400"><%= episode.show.title %></div>
              </td>
              <td class="p-4">
                <% if (episode.audioUrl) { %>
                  <span class="px-2 py-1 bg-blue-500/20 text-blue-400 text-xs rounded uppercase font-bold">Yes</span>
                <% } else { %>
                  <span class="px-2 py-1 bg-red-500/20 text-red-400 text-xs rounded uppercase font-bold">No</span>
                <% } %>
              </td>
              <td class="p-4 text-zinc-400 text-sm">
                <%= episode.publishedAt ? new Date(episode.publishedAt).toLocaleDateString() : '-' %>
              </td>
              <td class="p-4">
                <span class="px-2 py-1 bg-zinc-700 text-zinc-300 text-xs rounded uppercase font-bold">
                  <%= episode.status %>
                </span>
              </td>
              <td class="p-4 text-right">
                <form action="/admin/episodes/<%= episode.id %>/status" method="POST" class="inline-flex items-center gap-2">
                  <select name="status" class="bg-zinc-900 border border-zinc-700 text-sm rounded px-2 py-1 text-white focus:outline-none focus:border-white">
                    <option value="DRAFT" <%= episode.status === 'DRAFT' ? 'selected' : '' %>>DRAFT</option>
                    <option value="PUBLISHED" <%= episode.status === 'PUBLISHED' ? 'selected' : '' %>>PUBLISHED</option>
                    <option value="HIDDEN" <%= episode.status === 'HIDDEN' ? 'selected' : '' %>>HIDDEN</option>
                    <option value="ARCHIVED" <%= episode.status === 'ARCHIVED' ? 'selected' : '' %>>ARCHIVED</option>
                    <option value="REMOVED" <%= episode.status === 'REMOVED' ? 'selected' : '' %>>REMOVED</option>
                  </select>
                  <button type="submit" class="bg-white text-black px-3 py-1 rounded text-sm font-bold hover:bg-zinc-200 transition-colors">
                    Save
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="5" class="p-8 text-center text-zinc-500">No episodes found.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
