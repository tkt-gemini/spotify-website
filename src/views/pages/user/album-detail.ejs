<div class="mb-12">
  <!-- Album Header -->
  <div class="flex items-end gap-6 mb-8 mt-4">
    <div class="w-48 h-48 shadow-2xl rounded overflow-hidden bg-zinc-900 flex-shrink-0">
      <% if (album.coverUrl) { %>
        <img src="<%= album.coverUrl %>" alt="<%= album.title %>" class="w-full h-full object-cover">
      <% } else { %>
        <div class="w-full h-full flex items-center justify-center text-zinc-700 bg-zinc-800">
          <svg class="w-24 h-24" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 14.5c-2.49 0-4.5-2.01-4.5-4.5S9.51 7.5 12 7.5s4.5 2.01 4.5 4.5-2.01 4.5-4.5 4.5zm0-5.5c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1z"/></svg>
        </div>
      <% } %>
    </div>
    <div class="flex flex-col gap-2">
      <span class="text-sm font-bold uppercase tracking-wider">Album</span>
      <h1 class="text-5xl font-bold mb-2"><%= album.title %></h1>
      <div class="flex items-center gap-2 text-sm text-zinc-300 font-bold">
        <% if (album.artist && album.artist.avatarUrl) { %>
          <img src="<%= album.artist.avatarUrl %>" class="w-6 h-6 rounded-full object-cover">
        <% } %>
        <a href="/app/artists/<%= album.artistId %>" class="hover:underline"><%= album.artist ? album.artist.name : 'Unknown Artist' %></a>
        <span class="text-zinc-500">•</span>
        <span><%= album.releaseDate ? new Date(album.releaseDate).getFullYear() : 'Unknown Year' %></span>
        <span class="text-zinc-500">•</span>
        <span><%= tracks.length %> songs</span>
      </div>
    </div>
  </div>

  <!-- Actions -->
  <div class="flex items-center gap-6 mb-8">
    <button class="w-14 h-14 bg-green-500 rounded-full flex items-center justify-center text-black hover:scale-105 hover:bg-green-400 transition-all">
      <svg class="w-8 h-8 ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
    </button>
    <button 
      class="js-save-album-btn text-zinc-400 hover:text-white hover:scale-105 transition-all"
      data-album-id="<%= album.id %>"
      data-saved="<%= isSaved ? 'true' : 'false' %>"
      aria-label="Save to Your Library">
      <svg class="w-9 h-9" fill="<%= isSaved ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24" class="<%= isSaved ? 'text-green-500' : '' %>">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
      </svg>
    </button>
  </div>

  <!-- Tracks -->
  <div>
    <% if (tracks && tracks.length > 0) { %>
      <!-- Table Header -->
      <div class="flex items-center gap-4 px-3 py-2 border-b border-zinc-800 text-sm text-zinc-400 mb-2">
        <div class="w-6 text-right">#</div>
        <div class="flex-1">Title</div>
        <div class="w-16 text-right">
          <svg class="w-4 h-4 inline" fill="currentColor" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/><path d="M12.5 7H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
        </div>
        <div class="w-10"></div>
      </div>
      
      <div class="flex flex-col">
        <% tracks.forEach((track, index) => { %>
          <div class="flex items-center gap-4 p-3 hover:bg-zinc-800/50 rounded-md group">
            <div class="w-6 text-right text-zinc-400 text-sm group-hover:hidden"><%= index + 1 %></div>
            <div class="w-6 text-right hidden group-hover:block">
              <% if (track.audioUrl) { %>
                <button class="js-play-entity text-white flex items-center justify-center w-full h-full" data-entity-type="track" data-entity-id="<%= track.id %>">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </button>
              <% } else { %>
                <span class="text-zinc-600">-</span>
              <% } %>
            </div>
            
            <div class="flex flex-col flex-1 truncate">
              <span class="text-white font-medium truncate"><%= track.title %></span>
              <span class="text-sm text-zinc-400 mt-0.5 hover:underline cursor-pointer"><%= album.artist ? album.artist.name : 'Unknown Artist' %></span>
            </div>
            
            <div class="w-16 text-right text-zinc-400 text-sm">
              <%= Math.floor(track.duration / 60) %>:<%= (track.duration % 60).toString().padStart(2, '0') %>
            </div>
            
            <button class="js-like-btn w-10 text-center opacity-0 group-hover:opacity-100 transition-opacity" data-track-id="<%= track.id %>" data-liked="false">
              <svg class="w-5 h-5 mx-auto text-zinc-400 hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            </button>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-zinc-500 py-4">No tracks available in this album.</div>
    <% } %>
  </div>
</div>
