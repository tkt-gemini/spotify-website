<div class="mb-12">
  <!-- Artist Header -->
  <div class="flex items-end gap-6 mb-8 mt-4">
    <div class="w-48 h-48 rounded-full shadow-2xl overflow-hidden bg-zinc-900 flex-shrink-0">
      <% if (artist.avatarUrl) { %>
        <img src="<%= artist.avatarUrl %>" alt="<%= artist.name %>" class="w-full h-full object-cover">
      <% } else { %>
        <div class="w-full h-full flex items-center justify-center text-zinc-700 bg-zinc-800">
          <svg class="w-24 h-24" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
        </div>
      <% } %>
    </div>
    <div class="flex flex-col gap-2">
      <span class="text-sm font-bold uppercase tracking-wider">Artist</span>
      <h1 class="text-6xl font-bold mb-2"><%= artist.name %></h1>
      <% if (artist.bio) { %>
        <p class="text-zinc-400 max-w-2xl"><%= artist.bio %></p>
      <% } %>
    </div>
  </div>

  <!-- Actions -->
  <div class="flex items-center gap-4 mb-8">
    <button class="w-14 h-14 bg-green-500 rounded-full flex items-center justify-center text-black hover:scale-105 hover:bg-green-400 transition-all">
      <svg class="w-8 h-8 ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
    </button>
    <button 
      class="js-follow-artist-btn border <%= isFollowed ? 'border-white text-white' : 'border-zinc-500 text-zinc-300' %> px-4 py-1.5 rounded-full text-sm font-bold hover:border-white hover:scale-105 transition-all"
      data-artist-id="<%= artist.id %>"
      data-followed="<%= isFollowed ? 'true' : 'false' %>">
      <%= isFollowed ? 'Following' : 'Follow' %>
    </button>
  </div>

  <!-- Popular Tracks -->
  <div class="mb-12">
    <h2 class="text-2xl font-bold mb-4">Popular</h2>
    <% if (tracks && tracks.length > 0) { %>
      <div class="flex flex-col">
        <% tracks.forEach((track, index) => { %>
          <div class="flex items-center gap-4 p-3 hover:bg-zinc-800/50 rounded-md group">
            <div class="w-6 text-right text-zinc-400 text-sm"><%= index + 1 %></div>
            <div class="relative w-10 h-10 bg-zinc-800 rounded overflow-hidden flex-shrink-0">
              <% if (track.coverUrl) { %>
                <img src="<%= track.coverUrl %>" class="w-full h-full object-cover">
              <% } %>
              <% if (track.audioUrl) { %>
                <button class="js-play-entity absolute inset-0 bg-black/60 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity" data-entity-type="track" data-entity-id="<%= track.id %>">
                  <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </button>
              <% } %>
            </div>
            <div class="flex flex-col flex-1 truncate">
              <span class="text-white font-medium truncate"><%= track.title %></span>
            </div>
            <div class="w-16 text-right text-zinc-400 text-sm">
              <%= Math.floor(track.duration / 60) %>:<%= (track.duration % 60).toString().padStart(2, '0') %>
            </div>
            <button class="js-like-btn w-10 text-center opacity-0 group-hover:opacity-100 transition-opacity" data-track-id="<%= track.id %>" data-liked="false">
              <svg class="w-5 h-5 mx-auto text-zinc-400 hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            </button>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-zinc-500">No tracks available.</div>
    <% } %>
  </div>

  <!-- Albums -->
  <div>
    <h2 class="text-2xl font-bold mb-4">Albums</h2>
    <% if (albums && albums.length > 0) { %>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
        <% albums.forEach(album => { %>
          <a href="/app/albums/<%= album.id %>" class="bg-zinc-800/40 p-4 rounded-md hover:bg-zinc-800 transition-colors group relative flex flex-col">
            <div class="relative w-full aspect-square mb-4 shadow-lg rounded overflow-hidden bg-zinc-900">
              <% if (album.coverUrl) { %>
                <img src="<%= album.coverUrl %>" alt="<%= album.title %>" class="w-full h-full object-cover">
              <% } else { %>
                <div class="w-full h-full flex items-center justify-center text-zinc-700 bg-zinc-800">
                  <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 14.5c-2.49 0-4.5-2.01-4.5-4.5S9.51 7.5 12 7.5s4.5 2.01 4.5 4.5-2.01 4.5-4.5 4.5zm0-5.5c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1z"/></svg>
                </div>
              <% } %>
            </div>
            <h3 class="font-bold text-white truncate"><%= album.title %></h3>
            <p class="text-sm text-zinc-400 mt-1"><%= album.releaseDate ? new Date(album.releaseDate).getFullYear() : 'Unknown Year' %> • Album</p>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-zinc-500">No albums available.</div>
    <% } %>
  </div>
</div>
