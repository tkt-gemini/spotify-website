<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>500 - Internal Server Error | Spotify Clone</title>
  <link href="/css/tailwind.css" rel="stylesheet">
  <link href="/css/index.css" rel="stylesheet">
  <style>
    body { background-color: #121212; color: white; font-family: 'Circular', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
  </style>
</head>
<body class="h-screen flex items-center justify-center text-center">
  <div>
    <img src="/icons/spotify.svg" alt="Spotify Logo" class="h-16 w-16 mx-auto mb-6 text-white" />
    <h1 class="text-5xl font-bold mb-4">500</h1>
    <p class="text-xl text-zinc-400 mb-4">Oops! Something went wrong on our end.</p>
    <p class="text-sm text-zinc-500 mb-8 max-w-md mx-auto">
      <%= typeof message !== 'undefined' ? message : 'An unexpected error occurred. Please try again later.' %>
    </p>
    <a href="/app/home" class="bg-white text-black px-8 py-3 rounded-full font-bold hover:scale-105 transition-transform inline-block">
      Go back to Home
    </a>
  </div>
</body>
</html>
