<div class="text-center">
  <h2 class="text-3xl font-bold mb-6">Sign up for free to start listening.</h2>
</div>

<% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
  <div class="bg-red-500/10 text-red-500 border border-red-500/50 p-3 rounded text-sm mb-4">
    <%= errorMessage %>
  </div>
<% } %>

<form action="/register" method="POST" class="flex flex-col gap-4">
  <div class="flex flex-col gap-1">
    <label for="name" class="text-sm font-bold">What should we call you?</label>
    <input type="text" id="name" name="name" placeholder="Enter a profile name" class="p-3 bg-zinc-800 border border-zinc-700 rounded text-white focus:outline-none focus:border-green-500 transition-colors" required>
  </div>

  <div class="flex flex-col gap-1">
    <label for="email" class="text-sm font-bold">What's your email?</label>
    <input type="email" id="email" name="email" placeholder="Enter your email" class="p-3 bg-zinc-800 border border-zinc-700 rounded text-white focus:outline-none focus:border-green-500 transition-colors" required>
  </div>
  
  <div class="flex flex-col gap-1">
    <label for="password" class="text-sm font-bold">Create a password</label>
    <input type="password" id="password" name="password" placeholder="Create a password (min 6 characters)" minlength="6" class="p-3 bg-zinc-800 border border-zinc-700 rounded text-white focus:outline-none focus:border-green-500 transition-colors" required>
  </div>
  
  <button type="submit" class="mt-4 bg-green-500 text-black font-bold p-3 rounded-full hover:scale-105 hover:bg-green-400 transition-all">Sign Up</button>
</form>

<div class="mt-8 pt-6 border-t border-zinc-800 text-center">
  <p class="text-zinc-400">Have an account? <a href="/login" class="text-white hover:text-green-500 font-bold underline transition-colors">Log in</a></p>
</div>
