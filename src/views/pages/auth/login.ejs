<h2 class="text-2xl mb-4">Login</h2>
<form action="/login" method="POST" class="flex flex-col gap-4 max-w-sm">
  <input type="email" name="email" placeholder="Email" class="p-2 text-black" required>
  <input type="password" name="password" placeholder="Password" class="p-2 text-black" required>
  <button type="submit" class="bg-green-500 text-black font-bold p-2 rounded">Log In</button>
</form>
