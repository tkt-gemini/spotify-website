<div class="text-center">
  <h2 class="text-3xl font-bold mb-6">Log in to Spotify Clone</h2>
</div>

<% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
  <div class="bg-red-500/10 text-red-500 border border-red-500/50 p-3 rounded text-sm mb-4">
    <%= errorMessage %>
  </div>
<% } %>

<form action="/login" method="POST" class="flex flex-col gap-4">
  <div class="flex flex-col gap-1">
    <label for="email" class="text-sm font-bold">Email address</label>
    <input type="email" id="email" name="email" placeholder="Email" class="p-3 bg-zinc-800 border border-zinc-700 rounded text-white focus:outline-none focus:border-green-500 transition-colors" required>
  </div>
  
  <div class="flex flex-col gap-1">
    <label for="password" class="text-sm font-bold">Password</label>
    <input type="password" id="password" name="password" placeholder="Password" class="p-3 bg-zinc-800 border border-zinc-700 rounded text-white focus:outline-none focus:border-green-500 transition-colors" required>
  </div>
  
  <button type="submit" class="mt-4 bg-green-500 text-black font-bold p-3 rounded-full hover:scale-105 hover:bg-green-400 transition-all">Log In</button>
</form>

<div class="mt-8 pt-6 border-t border-zinc-800 text-center">
  <p class="text-zinc-400">Don't have an account? <a href="/register" class="text-white hover:text-green-500 font-bold underline transition-colors">Sign up for Spotify Clone</a></p>
</div>
