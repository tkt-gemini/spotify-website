<div class="max-w-4xl mx-auto py-12">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold">Select Artist</h1>
    <a href="/artist/new" class="bg-white text-black px-4 py-2 rounded-full font-bold text-sm hover:scale-105 transition-transform">
      Create Artist
    </a>
  </div>

  <% if (teamMembers && teamMembers.length > 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% teamMembers.forEach(tm => { %>
        <a href="/artist/<%= tm.artist.id %>/overview" class="bg-zinc-800/40 hover:bg-zinc-800 p-6 rounded-lg transition-colors group flex items-center gap-4">
          <div class="w-16 h-16 rounded-full bg-zinc-700 flex-shrink-0 overflow-hidden shadow-lg group-hover:scale-105 transition-transform">
            <% if (tm.artist.avatarUrl) { %>
              <img src="<%= tm.artist.avatarUrl %>" class="w-full h-full object-cover">
            <% } else { %>
              <div class="w-full h-full flex items-center justify-center text-zinc-500">
                <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
              </div>
            <% } %>
          </div>
          <div class="flex flex-col">
            <span class="font-bold text-white text-lg"><%= tm.artist.name %></span>
            <span class="text-xs text-zinc-400 bg-zinc-700/50 w-max px-2 py-0.5 rounded mt-1 uppercase"><%= tm.role %></span>
          </div>
        </a>
      <% }) %>
    </div>
  <% } else { %>
    <div class="text-center py-20 bg-zinc-800/20 rounded-lg border border-zinc-800 border-dashed">
      <svg class="w-16 h-16 text-zinc-600 mx-auto mb-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
      <h2 class="text-xl font-bold mb-2">You aren't managing any artists</h2>
      <p class="text-zinc-400 mb-6 max-w-md mx-auto">Create a new artist profile to start uploading your music and reaching your fans.</p>
      <a href="/artist/new" class="bg-white text-black px-6 py-3 rounded-full font-bold hover:scale-105 transition-transform inline-block">
        Create Artist Profile
      </a>
    </div>
  <% } %>
</div>
