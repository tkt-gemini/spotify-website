<div class="max-w-2xl mx-auto py-12">
  <div class="mb-8">
    <a href="/artist/select" class="text-zinc-400 hover:text-white text-sm mb-4 inline-block">&larr; Back to Artists</a>
    <h1 class="text-3xl font-bold">Create Artist Profile</h1>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-500/10 border border-red-500 text-red-500 p-4 rounded-md mb-6">
      <%= error %>
    </div>
  <% } %>

  <form action="/artist" method="POST" enctype="multipart/form-data" class="space-y-6 bg-zinc-900 p-8 rounded-lg">
    <div>
      <label for="name" class="block text-sm font-bold mb-2">Artist Name <span class="text-red-500">*</span></label>
      <input type="text" id="name" name="name" required class="w-full bg-zinc-800 border border-zinc-700 rounded p-3 focus:outline-none focus:border-white transition-colors" placeholder="e.g. The Beatles">
    </div>

    <div>
      <label for="bio" class="block text-sm font-bold mb-2">Biography (Optional)</label>
      <textarea id="bio" name="bio" rows="4" class="w-full bg-zinc-800 border border-zinc-700 rounded p-3 focus:outline-none focus:border-white transition-colors" placeholder="Tell your fans about yourself..."></textarea>
    </div>

    <div>
      <label for="avatar" class="block text-sm font-bold mb-2">Avatar Image (Optional)</label>
      <input type="file" id="avatar" name="avatar" accept="image/jpeg, image/png, image/webp" class="w-full text-zinc-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-zinc-800 file:text-white hover:file:bg-zinc-700 transition-colors">
      <p class="text-xs text-zinc-500 mt-2">Max 10MB. JPEG, PNG, or WEBP.</p>
    </div>

    <div>
      <label for="banner" class="block text-sm font-bold mb-2">Banner Image (Optional)</label>
      <input type="file" id="banner" name="banner" accept="image/jpeg, image/png, image/webp" class="w-full text-zinc-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-zinc-800 file:text-white hover:file:bg-zinc-700 transition-colors">
      <p class="text-xs text-zinc-500 mt-2">Max 10MB. JPEG, PNG, or WEBP. Appears at the top of your profile.</p>
    </div>

    <div class="pt-4 border-t border-zinc-800 flex justify-end gap-4">
      <a href="/artist/select" class="px-6 py-3 font-bold text-zinc-300 hover:text-white">Cancel</a>
      <button type="submit" class="bg-green-500 text-black px-8 py-3 rounded-full font-bold hover:scale-105 transition-transform">Create Profile</button>
    </div>
  </form>
</div>
