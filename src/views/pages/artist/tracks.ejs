<div class="max-w-5xl mx-auto">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold">Tracks</h1>
    <a href="/artist/<%= currentArtist.id %>/tracks/new" class="bg-white text-black px-4 py-2 rounded-full font-bold text-sm hover:scale-105 transition-transform">
      New Track
    </a>
  </div>

  <% if (tracks && tracks.length > 0) { %>
    <div class="bg-zinc-800/30 rounded-lg overflow-hidden">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="border-b border-zinc-800 text-zinc-400 text-sm">
            <th class="p-4 font-normal uppercase tracking-wider">Title</th>
            <th class="p-4 font-normal uppercase tracking-wider">Status</th>
            <th class="p-4 font-normal uppercase tracking-wider">Audio File</th>
            <th class="p-4 font-normal uppercase tracking-wider text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% tracks.forEach(track => { %>
            <tr class="border-b border-zinc-800/50 hover:bg-zinc-800/50 transition-colors group">
              <td class="p-4 font-bold text-white flex items-center gap-4">
                <% if (track.coverUrl) { %>
                  <img src="<%= track.coverUrl %>" class="w-10 h-10 rounded object-cover">
                <% } else { %>
                  <div class="w-10 h-10 rounded bg-zinc-700 flex items-center justify-center">
                    <svg class="w-4 h-4 text-zinc-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/></svg>
                  </div>
                <% } %>
                <div class="flex flex-col">
                  <span><%= track.title %></span>
                  <span class="text-xs text-zinc-500 font-normal"><%= new Date(track.createdAt).toLocaleDateString() %></span>
                </div>
              </td>
              <td class="p-4">
                <% if (track.status === 'PUBLISHED') { %>
                  <span class="px-2 py-1 bg-green-500/20 text-green-500 text-xs rounded-full uppercase font-bold">Published</span>
                <% } else { %>
                  <span class="px-2 py-1 bg-zinc-700 text-zinc-300 text-xs rounded-full uppercase font-bold">Draft</span>
                <% } %>
              </td>
              <td class="p-4">
                <% if (track.audioUrl) { %>
                  <a href="<%= track.audioUrl %>" target="_blank" class="text-blue-400 hover:text-blue-300 text-sm flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072M18.364 5.636a9 9 0 010 12.728M11 15v-6a2 2 0 00-3.414-1.414l-2 2A2 2 0 014.172 10H3a2 2 0 00-2 2v4a2 2 0 002 2h1.172a2 2 0 011.414.586l2 2A2 2 0 0011 19z"></path></svg>
                    Has Audio
                  </a>
                <% } else { %>
                  <span class="text-zinc-500 text-sm italic">Missing</span>
                <% } %>
              </td>
              <td class="p-4 text-right">
                <div class="flex items-center justify-end gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                  <a href="/artist/<%= currentArtist.id %>/tracks/<%= track.id %>/edit" class="text-zinc-400 hover:text-white transition-colors" title="Edit">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                  </a>
                  <% if (track.status === 'DRAFT' && track.audioUrl) { %>
                    <form action="/artist/<%= currentArtist.id %>/tracks/<%= track.id %>/publish" method="POST" class="m-0 inline-block">
                      <button type="submit" class="text-green-500 hover:text-green-400 transition-colors" title="Publish">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                      </button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="text-center py-20 bg-zinc-800/20 rounded-lg border border-zinc-800 border-dashed">
      <svg class="w-16 h-16 text-zinc-600 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path></svg>
      <h2 class="text-xl font-bold mb-2">No tracks yet</h2>
      <p class="text-zinc-400 mb-6 max-w-md mx-auto">Upload your first track to share with the world.</p>
      <a href="/artist/<%= currentArtist.id %>/tracks/new" class="bg-white text-black px-6 py-3 rounded-full font-bold hover:scale-105 transition-transform inline-block">
        Upload Track
      </a>
    </div>
  <% } %>
</div>
