<div class="max-w-6xl mx-auto">
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-3xl font-bold">Albums</h1>
      <p class="text-zinc-400 mt-2">Manage your albums and EPs.</p>
    </div>
    <% if (['OWNER', 'MANAGER', 'EDITOR'].includes(artistRole)) { %>
      <a href="/artist/<%= currentArtist.id %>/albums/new" class="bg-white text-black px-6 py-2 rounded-full font-bold hover:scale-105 transition-transform">
        Create Album
      </a>
    <% } %>
  </div>

  <% if (albums && albums.length > 0) { %>
    <div class="bg-zinc-900 rounded-lg overflow-hidden">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="border-b border-zinc-800 text-zinc-400 text-sm uppercase tracking-wider">
            <th class="p-4 font-bold">Album</th>
            <th class="p-4 font-bold">Release Date</th>
            <th class="p-4 font-bold">Status</th>
            <th class="p-4 font-bold text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% albums.forEach(album => { %>
            <tr class="border-b border-zinc-800/50 hover:bg-zinc-800/50 transition-colors group">
              <td class="p-4">
                <div class="flex items-center gap-4">
                  <div class="w-12 h-12 bg-zinc-800 rounded flex-shrink-0 overflow-hidden">
                    <% if (album.coverUrl) { %>
                      <img src="<%= album.coverUrl %>" class="w-full h-full object-cover">
                    <% } else { %>
                      <div class="w-full h-full flex items-center justify-center">
                        <svg class="w-6 h-6 text-zinc-600" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 14.5c-2.49 0-4.5-2.01-4.5-4.5S9.51 7.5 12 7.5s4.5 2.01 4.5 4.5-2.01 4.5-4.5 4.5zm0-5.5c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1z"/></svg>
                      </div>
                    <% } %>
                  </div>
                  <div>
                    <div class="font-bold text-white"><%= album.title %></div>
                  </div>
                </div>
              </td>
              <td class="p-4 text-zinc-400 text-sm">
                <%= album.releaseDate ? album.releaseDate.toLocaleDateString() : 'N/A' %>
              </td>
              <td class="p-4">
                <% if (album.status === 'PUBLISHED') { %>
                  <span class="px-2 py-1 bg-green-500/20 text-green-500 text-xs rounded-full uppercase font-bold">Published</span>
                <% } else { %>
                  <span class="px-2 py-1 bg-zinc-700 text-zinc-300 text-xs rounded-full uppercase font-bold">Draft</span>
                <% } %>
              </td>
              <td class="p-4 text-right">
                <div class="flex items-center justify-end gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                  <% if (['OWNER', 'MANAGER', 'EDITOR'].includes(artistRole)) { %>
                    <a href="/artist/<%= currentArtist.id %>/albums/<%= album.id %>/edit" class="text-zinc-400 hover:text-white" title="Edit Album">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                    </a>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <%- include('../../partials/empty-state', {
      icon: '<svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>',
      title: 'No albums found',
      description: 'Create your first album or EP to group your tracks.'
    }) %>
  <% } %>
</div>
