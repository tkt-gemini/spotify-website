<%
  const _tracks = typeof tracks !== 'undefined' ? tracks : [];
  const _contextName = typeof contextName !== 'undefined' ? contextName : '';
  const _playlistId = typeof playlistId !== 'undefined' ? playlistId : null;
  const _showAlbum = typeof showAlbum !== 'undefined' ? showAlbum : true;
  const _showDateAdded = typeof showDateAdded !== 'undefined' ? showDateAdded : true;
  const _libraryItems = typeof libraryItems !== 'undefined' ? libraryItems : null;
  
  // Calculate grid columns based on visibility flags
  let gridCols = ['32px', '6fr'];
  if (_showAlbum) gridCols.push('4fr');
  if (_showDateAdded) gridCols.push('3fr');
  gridCols.push('minmax(120px, 1fr)');
  const gridTemplate = gridCols.join(' ');
%>

<div class="w-full mt-4">
  <!-- Table Header -->
  <div class="grid gap-4 px-4 py-2 border-b border-spotify-divider text-sm text-spotify-subdued font-medium items-center mb-4 sticky top-[64px] bg-[#121212]/90 backdrop-blur-md z-20" style="grid-template-columns: <%= gridTemplate %>;">
    <div class="text-center">#</div>
    <div>Title</div>
    <% if (_showAlbum) { %><div>Album</div><% } %>
    <% if (_showDateAdded) { %><div>Date added</div><% } %>
    <div class="flex justify-end pr-4">
      <div class="w-10 flex justify-end mr-[36px]">
        <i class="ph ph-clock text-[18px]"></i>
      </div>
    </div>
  </div>

  <!-- Table Body -->
  <div class="track-context-container flex flex-col gap-1 pb-10" data-context-name="<%= _contextName %>">
    <% if (_tracks && _tracks.length > 0) { %>
      <% _tracks.forEach((track, index) => { 
           // Calculate Date Added
           let addedDate = '-';
           if (_showDateAdded) {
             let d = null;
             if (_libraryItems) {
               d = _libraryItems.find(i => i.itemId === track.id)?.createdAt;
             } else if (track.PlaylistTrack) {
               d = track.PlaylistTrack.createdAt;
             } else {
               d = track.createdAt;
             }
             if (d) {
               const diff = Math.floor((Date.now() - new Date(d)) / 86400000);
               if (diff === 0) addedDate = 'Today';
               else if (diff === 1) addedDate = 'Yesterday';
               else if (diff < 7) addedDate = diff + ' days ago';
               else if (diff < 30) addedDate = Math.floor(diff/7) + ' weeks ago';
               else addedDate = new Date(d).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'});
             }
           }
      %>
        <div class="group flex items-center justify-between px-4 py-2 hover:bg-spotify-elevated rounded-md cursor-pointer transition-colors text-sm text-spotify-subdued" data-type="track" data-id="<%= track.id %>" <%= _playlistId ? `data-playlist-id="${_playlistId}"` : '' %>>
          <div class="flex items-center gap-4 w-full" style="grid-template-columns: <%= gridTemplate %>; display: grid;">
            
            <div class="w-8 flex items-center justify-center shrink-0 text-base">
              <span class="group-hover:hidden"><%= index + 1 %></span>
              <button class="hidden group-hover:flex items-center justify-center hover:scale-105" onclick="event.preventDefault(); window.playTrack('<%= track.id %>', '<%= track.title.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= track.artist.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= track.cover %>', '<%= track.audio %>')">
                <i class="ph-fill ph-play text-white text-[16px] play-btn-icon" ></i>
              </button>
            </div>
            
            <div class="flex items-center gap-3 pr-2 min-w-0">
              <div class="w-10 h-10 bg-spotify-card-hover shrink-0 rounded flex items-center justify-center overflow-hidden">
                <% if (track.cover) { %>
                  <img src="<%= track.cover %>" class="w-full h-full object-cover">
                <% } else { %>
                  <i class="ph ph-music-note text-gray-500 text-[20px]"></i>
                <% } %>
              </div>
              <div class="flex flex-col overflow-hidden">
                <span class="text-white font-medium truncate text-base mb-0.5"><%= track.title %></span>
                <a href="/artist/<%= encodeURIComponent(track.artist) %>" class="nav-item hover:underline truncate hover:text-white"><%= track.artist %></a>
              </div>
            </div>

            <% if (_showAlbum) { %>
              <div class="truncate pr-2 hover:text-white hover:underline"><%= track.album || track.title %></div>
            <% } %>
            
            <% if (_showDateAdded) { %>
              <div class="truncate pr-2"><%= addedDate %></div>
            <% } %>
            
            <div class="flex items-center justify-end pr-4 gap-4 font-medium tracking-wide h-full">
              <!-- Always show heart filled if libraryItems exists (Liked Songs context), otherwise default state -->
              <button class="btn-like-track <%= _libraryItems ? 'text-spotify-green' : 'text-spotify-subdued' %> hover:text-white opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center h-full" onclick="toggleLike(this, '<%= track.id %>', 'track')">
                <i class="ph <%= _libraryItems ? 'ph-fill ph-heart' : 'ph-heart' %> text-[20px] leading-none"></i>
              </button>
              
              <span class="w-10 text-right duration-display flex items-center justify-end h-full" data-audio-url="<%= track.audio %>">--:--</span>
              
              <button class="cm-trigger text-spotify-subdued hover:text-white opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center h-full">
                <i class="ph ph-dots-three text-[20px] leading-none"></i>
              </button>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="w-full py-16 flex flex-col items-center justify-center text-center">
        <i class="ph ph-music-note text-[64px] text-gray-400 mb-6"></i>
        <h3 class="text-xl font-bold text-white mb-2"><%= _contextName === 'Liked Songs' ? 'Songs you like will appear here' : 'Let\'s find something for your playlist' %></h3>
        <% if (_contextName !== 'Liked Songs') { %>
          <a href="/search" class="nav-item px-8 py-3 bg-white text-black font-bold rounded-full hover:scale-105 transition-transform hover:bg-gray-100 mt-4">Find Songs</a>
        <% } else { %>
          <p class="text-spotify-subdued text-sm">Save songs by tapping the heart icon.</p>
        <% } %>
      </div>
    <% } %>
  </div>
</div>
