<header class="absolute top-0 left-0 w-full h-16 flex items-center justify-between px-6 bg-transparent z-50 transition-colors duration-300 pointer-events-none" id="top-bar-header">
  
  <!-- Left Side (Empty spacer to help center) -->
  <div class="flex items-center w-1/4 pointer-events-auto">
    <!-- Optional: Add Spotify logo here -->
  </div>

  <!-- Center (Home + Search) -->
  <div class="flex items-center justify-center gap-2 w-1/2 max-w-[600px] pointer-events-auto">
    <!-- Home Button -->
    <a href="/" class="nav-item w-12 h-12 shrink-0 flex items-center justify-center rounded-full bg-spotify-elevated hover:scale-105 transition-transform text-white">
      <i class="ph ph-house text-[28px]" ></i>
    </a>
    
    <!-- Search Bar -->
    <div id="topbar-search-container" class="relative flex-1 w-full min-w-[350px]">
      <div class="relative w-full flex items-center bg-spotify-elevated hover:bg-[#2a2a2a] hover:border-[#444] border border-spotify-elevated-hover rounded-full px-3 py-2 group transition-colors">
        <i class="ph ph-magnifying-glass text-spotify-subdued group-hover:text-white ml-1 shrink-0"></i>
        <input id="topbar-search-input" type="text" placeholder="What do you want to play?" class="bg-transparent border-none outline-none text-white text-[15px] font-medium w-full ml-3 placeholder-[#a7a7a7]">
        <button id="topbar-search-clear" class="hidden items-center justify-center shrink-0 pr-2">
          <i class="ph ph-x text-spotify-subdued hover:text-white cursor-pointer"></i>
        </button>
      </div>
      <!-- Dropdown Results -->
      <div id="topbar-search-dropdown" class="absolute top-[110%] left-0 w-full bg-spotify-elevated rounded-lg shadow-2xl border border-spotify-elevated-hover hidden flex-col max-h-[60vh] overflow-y-auto z-50 p-2">
      </div>
    </div>
  </div>

  <!-- Right Side (Profile) -->
  <div class="flex items-center justify-end w-1/4 pointer-events-auto gap-4">
    <% if (typeof user !== 'undefined' && user) { %>
      
      <!-- Profile Button -->
      <div class="relative group">
        <button id="topbar-profile-btn" class="w-8 h-8 rounded-full bg-black border-[3px] border-spotify-divider hover:scale-105 transition-transform flex items-center justify-center overflow-hidden">
          <% if (user.avatar) { %>
            <img src="<%= user.avatar %>" class="w-full h-full object-cover">
          <% } else { %>
            <i class="ph ph-user text-spotify-subdued text-xl"></i>
          <% } %>
        </button>
        <!-- Dropdown (CSS hover) -->
        <div class="absolute right-0 top-full pt-2 hidden group-hover:block z-[100] w-48">
          <div class="flex flex-col bg-spotify-card-hover p-1 rounded shadow-[0_16px_24px_rgba(0,0,0,0.3),_0_6px_8px_rgba(0,0,0,0.2)] w-full text-sm text-white/90">
            <a href="/profile" class="nav-item px-3 py-2.5 hover:bg-[#3e3e3e] rounded-sm cursor-pointer">Profile</a>
            <a href="/studio" class="px-3 py-2.5 hover:bg-[#3e3e3e] flex justify-between rounded-sm cursor-pointer text-spotify-green hover:text-spotify-green-hover">
              <span>Studio</span>
              <i class="ph ph-arrow-square-out text-lg"></i>
            </a>

            <% if (user.isAdmin) { %>
              <div class="h-[1px] bg-white/10 my-1 w-full"></div>
              <a href="/admin" class="nav-item px-3 py-2.5 hover:bg-[#3e3e3e] flex justify-between rounded-sm cursor-pointer text-[#e2b83a] hover:text-[#ffd659]">
                <span>Admin Panel</span>
                <i class="ph ph-shield-check text-lg"></i>
              </a>
            <% } %>

            <div class="h-[1px] bg-white/10 my-1 w-full"></div>
            <a href="/auth/logout" class="px-3 py-2.5 hover:bg-[#3e3e3e] rounded-sm cursor-pointer">Log out</a>
          </div>
        </div>
      </div>
    <% } else { %>
      <!-- Guest State -->
      <a href="/auth/register" class="text-spotify-subdued font-bold text-sm hover:text-white hover:scale-105 transition-all">Sign up</a>
      <a href="/auth/login" class="px-8 py-3 bg-white text-black font-bold text-base rounded-full hover:scale-105 hover:bg-gray-100 transition-all">Log in</a>
    <% } %>
  </div>

</header>
