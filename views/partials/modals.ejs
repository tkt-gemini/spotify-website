      </button>
      <button id="cs-show-modal-save"
        class="px-6 py-2.5 bg-spotify-green hover:bg-spotify-green-hover text-black font-bold text-sm rounded-full transition-colors">
        Create Show
      </button>
    </div>
  </div>
</div>

<!-- Episode Editor Modal -->
<div id="cs-episode-modal" class="fixed inset-0 bg-black/80 flex items-center justify-center z-[110] hidden backdrop-blur-sm">
