          <option value="song">Song</option>
          <option value="podcast_episode">Podcast Episode (Audio)</option>
          <option value="audiobook_chapter">Audiobook Chapter</option>
        </select>
      </div>

      <div class="flex flex-col">
        <label class="text-xs font-bold text-[#a7a7a7] uppercase tracking-wider mb-1">Album (Optional)</label>
        <select id="sa-track-album-input" class="bg-[#3e3e3e] border border-white/10 focus:border-[#a259ff] text-white text-sm rounded-lg px-3 py-2.5 outline-none transition-colors">
