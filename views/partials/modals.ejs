        <div class="flex flex-col">
          <label class="text-xs font-bold text-[#a7a7a7] uppercase tracking-wider mb-1">Show Title *</label>
          <input type="text" id="cs-show-title-input"
            class="bg-[#3e3e3e] border border-white/10 focus:border-spotify-green text-white text-sm rounded-lg px-3 py-2.5 outline-none transition-colors"
