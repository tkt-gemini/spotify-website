      <label class="text-xs font-bold text-[#a7a7a7] uppercase tracking-wider mb-1">Description</label>
      <textarea id="cs-show-description-input" rows="3"
        class="bg-[#3e3e3e] border border-white/10 focus:border-spotify-green text-white text-sm rounded-lg px-3 py-2.5 outline-none resize-none transition-colors"
        placeholder="What is your podcast about?" maxlength="2000"></textarea>
    </div>

    <div class="flex justify-end gap-3">
      <button id="cs-show-modal-cancel"
        class="px-5 py-2.5 rounded-full text-[#a7a7a7] hover:text-white text-sm font-semibold transition-colors">
