        </div>
        <div class="flex gap-3">
          <div class="flex flex-col flex-1">
            <label class="text-xs font-bold text-[#a7a7a7] uppercase tracking-wider mb-1">Category</label>
            <select id="cs-show-category-input"
              class="bg-[#3e3e3e] border border-white/10 focus:border-spotify-green text-white text-sm rounded-lg px-3 py-2.5 outline-none transition-colors">
              <option value="">Select...</option>
              <option value="Technology">Technology</option>
              <option value="Business">Business</option>
              <option value="Education">Education</option>
              <option value="Arts">Arts</option>
              <option value="Comedy">Comedy</option>
              <option value="Health">Health &amp; Fitness</option>
              <option value="News">News</option>
              <option value="Science">Science</option>
              <option value="Society">Society &amp; Culture</option>
              <option value="True Crime">True Crime</option>
              <option value="Sports">Sports</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div class="flex flex-col flex-1">
            <label class="text-xs font-bold text-[#a7a7a7] uppercase tracking-wider mb-1">Language</label>
            <select id="cs-show-language-input"
              class="bg-[#3e3e3e] border border-white/10 focus:border-spotify-green text-white text-sm rounded-lg px-3 py-2.5 outline-none transition-colors">
              <option value="en">English</option>
              <option value="vi">Vietnamese</option>
              <option value="es">Spanish</option>
              <option value="fr">French</option>
              <option value="de">German</option>
              <option value="ja">Japanese</option>
              <option value="ko">Korean</option>
              <option value="zh">Chinese</option>
            </select>
          </div>
        </div>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" id="cs-show-explicit-input" class="w-4 h-4 accent-spotify-green">
          <span class="text-white text-sm font-semibold">Contains explicit content</span>
        </label>
      </div>
    </div>

    <!-- Description -->
