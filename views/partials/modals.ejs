          <% if (typeof albums !== 'undefined' && albums && albums.length > 0) { %>
            <% albums.forEach(a => { %>
              <option value="<%= a.id %>"><%= a.title %></option>
            <% }) %>
          <% } %>
        </select>
      </div>

      <div class="flex flex-col">
        <label class="text-xs font-bold text-[#a7a7a7] uppercase tracking-wider mb-1">Lyrics (Optional)</label>
        <textarea id="sa-track-lyrics-input"
          class="bg-[#3e3e3e] border border-white/10 focus:border-[#a259ff] text-white text-sm rounded-lg px-3 py-2.5 outline-none transition-colors min-h-[100px] resize-y"
          placeholder="Enter lyrics here..."></textarea>
      </div>

      <!-- Audio upload -->
      <div class="flex flex-col">
        <label class="text-xs font-bold text-[#a7a7a7] uppercase tracking-wider mb-1">Audio File *</label>
        <div id="sa-track-audio-drop"
          class="border-2 border-dashed border-white/20 hover:border-[#a259ff] rounded-xl p-5 text-center cursor-pointer transition-colors group">
          <i class="ph ph-file-audio text-[#727272] group-hover:text-[#a259ff] text-3xl mb-2 block transition-colors"></i>
          <p class="text-white text-sm font-semibold mb-1" id="sa-track-audio-filename">Click to select audio file</p>
          <p class="text-[#727272] text-xs">MP3, M4A, WAV, OGG · Max 50MB</p>
          <input type="file" id="sa-track-audio-input" accept=".mp3,.m4a,.wav,.ogg,.aac" class="hidden">
        </div>
      </div>
    </div>

    <div class="flex justify-end gap-3 mt-2">
      <button id="sa-track-modal-cancel"
        class="px-5 py-2.5 rounded-full text-[#a7a7a7] hover:text-white text-sm font-semibold transition-colors">
