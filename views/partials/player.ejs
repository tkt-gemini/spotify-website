<div class="player-container">
  <div class="player-left">
    <img id="player-cover" src="https://picsum.photos/seed/default/64/64" alt="Album Cover">
    <div class="player-track-info">
      <h4 id="player-title">No track selected</h4>
      <p id="player-artist">-</p>
    </div>
    <button class="like-btn"><i class="far fa-heart"></i></button>
  </div>

  <div class="player-center">
    <div class="player-controls">
      <button class="control-btn"><i class="fas fa-random"></i></button>
      <button class="control-btn"><i class="fas fa-step-backward"></i></button>
      <button class="play-pause-btn" id="play-pause-btn"><i class="fas fa-play-circle"></i></button>
      <button class="control-btn"><i class="fas fa-step-forward"></i></button>
      <button class="control-btn"><i class="fas fa-redo"></i></button>
    </div>
    <div class="progress-container">
      <span id="time-current">0:00</span>
      <div class="progress-bar-wrapper" id="progress-bar-wrapper">
        <div class="progress-bar" id="progress-bar"></div>
      </div>
      <span id="time-total">0:00</span>
    </div>
  </div>

  <div class="player-right">
    <i class="fas fa-volume-up"></i>
    <div class="volume-bar-wrapper" id="volume-bar-wrapper">
      <div class="volume-bar" id="volume-bar" style="width: 100%;"></div>
    </div>
  </div>

  <audio id="audio-element" preload="none"></audio>
</div>
