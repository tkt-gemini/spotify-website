<style>
  nav.is-collapsed .hide-on-collapse { display: none !important; }
  nav.is-collapsed .center-on-collapse { justify-content: center !important; padding-left: 0 !important; padding-right: 0 !important; }
  nav.is-collapsed .grid-center-on-collapse { grid-template-columns: 1fr !important; }
  nav.is-collapsed .w-full-on-collapse { width: 100% !important; display: flex !important; justify-content: center !important; }
</style>



<div class="bg-spotify-black rounded-lg w-full flex flex-col flex-1 min-h-0 overflow-hidden relative">
  <!-- Library Header -->
  <div class="px-4 py-2 flex items-center justify-between text-spotify-subdued font-bold text-sm h-14 shrink-0 shadow-[0_2px_10px_rgba(0,0,0,0.5)] z-10 center-on-collapse">
    <button id="toggle-library-btn" class="flex items-center gap-2 hover:text-white transition-colors duration-200 center-on-collapse">
      <i class="ph ph-book text-[28px] shrink-0"></i>
      <span class="hide-on-collapse">Your Library</span>
    </button>
    <div class="flex items-center gap-2 hide-on-collapse relative">
      <button id="create-new-dropdown-btn" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-spotify-elevated hover:text-white transition-colors" title="Create playlist or folder">
        <i class="ph ph-plus text-xl shrink-0"></i>
      </button>
      <!-- Dropdown -->
      <div id="create-new-dropdown" class="hidden absolute left-0 top-10 w-48 bg-spotify-card-hover rounded-md shadow-[0_8px_24px_rgba(0,0,0,0.5)] z-50 flex-col p-1 text-sm font-medium">
        <button id="create-playlist-btn" class="w-full px-3 py-2.5 rounded-sm hover:bg-[#3E3E3E] text-white text-left flex items-center gap-2 transition-colors">
          <i class="ph ph-music-notes-plus text-xl"></i> Create a new playlist
        </button>
        <button id="create-folder-btn" class="w-full px-3 py-2.5 rounded-sm hover:bg-[#3E3E3E] text-white text-left flex items-center gap-2 transition-colors">
          <i class="ph ph-folder-plus text-xl"></i> Create a playlist folder
        </button>
      </div>
    </div>
  </div>

  <!-- Library Filters -->
  <div class="px-4 py-2 flex gap-2 overflow-x-auto shrink-0 [&::-webkit-scrollbar]:hidden hide-on-collapse">
    <button class="library-filter px-3 py-1 rounded-full bg-spotify-elevated text-white text-sm font-medium hover:bg-spotify-elevated-hover transition-colors whitespace-nowrap" data-filter="playlist">Playlists</button>
    <button class="library-filter px-3 py-1 rounded-full bg-spotify-elevated text-white text-sm font-medium hover:bg-spotify-elevated-hover transition-colors whitespace-nowrap" data-filter="artist">Artists</button>
    <button class="library-filter px-3 py-1 rounded-full bg-spotify-elevated text-white text-sm font-medium hover:bg-spotify-elevated-hover transition-colors whitespace-nowrap" data-filter="podcast">Podcasts & Shows</button>
  </div>

  <!-- Library List -->
  <div class="flex-1 overflow-y-auto px-2 py-2">
    <!-- Search / Sort bar -->
    <div class="flex items-center justify-between px-2 mb-2 hide-on-collapse relative h-8">
      <button id="library-search-btn" class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-spotify-elevated text-spotify-subdued hover:text-white transition-colors z-0">
        <i class="ph ph-magnifying-glass text-[18px]"></i>
      </button>

      <!-- Search input container (Animated) -->
      <div id="library-search-container" class="absolute left-0 top-0 h-8 flex items-center bg-spotify-elevated rounded transition-all duration-300 ease-in-out w-8 opacity-0 pointer-events-none z-10 overflow-hidden">
        <i class="ph ph-magnifying-glass text-[18px] text-spotify-subdued ml-[6px] shrink-0"></i>
        <input type="text" id="library-search-input" placeholder="Search in Your Library" class="bg-transparent text-white text-sm px-2 w-full h-full focus:outline-none">
        <button id="library-search-close" class="text-spotify-subdued hover:text-white mr-2 shrink-0 hidden items-center justify-center">
          <i class="ph ph-x text-[16px]"></i>
        </button>
      </div>
      <!-- Sort Button & Dropdown -->
      <div class="relative shrink-0 ml-2">
        <button id="library-sort-btn" class="flex items-center gap-1 text-sm font-medium text-spotify-subdued hover:text-white transition-colors hover:scale-105 z-0">
          <span id="library-sort-label">Recents</span>
          <i class="ph ph-list text-[18px]"></i>
        </button>

        <!-- Dropdown Menu -->
        <div id="library-sort-dropdown" class="hidden absolute right-0 top-8 w-48 bg-spotify-card-hover rounded-md shadow-[0_8px_24px_rgba(0,0,0,0.5)] z-50 flex-col p-1 text-sm text-spotify-subdued font-medium">
          <span class="px-3 py-2 text-[11px] font-bold uppercase tracking-widest text-spotify-subdued block mb-1">Sort by</span>
          <button class="sort-option w-full px-3 py-2.5 rounded-sm hover:bg-[#3E3E3E] hover:text-white text-left flex items-center justify-between transition-colors" data-sort="recents">
            <span class="pointer-events-none">Recents</span>
            <i class="sort-dir-icon ph ph-arrow-up text-[18px] hidden pointer-events-none text-spotify-green"></i>
          </button>
          <button class="sort-option w-full px-3 py-2.5 rounded-sm hover:bg-[#3E3E3E] hover:text-white text-left flex items-center justify-between transition-colors" data-sort="alphabetical">
            <span class="pointer-events-none">Alphabetical</span>
            <i class="sort-dir-icon ph ph-arrow-up text-[18px] hidden pointer-events-none text-spotify-green"></i>
          </button>
        </div>
      </div>
    </div>

    <!-- The List Items -->
    <div id="library-list-container" class="flex flex-col">
      <!-- Liked Songs (Static Pinned Item) -->
      <a href="/collection/tracks" data-type="playlist" class="library-item nav-item flex items-center gap-3 p-2 rounded-md hover:bg-[#1a1a1a] transition-colors cursor-pointer center-on-collapse">
        <div class="w-12 h-12 bg-gradient-to-br from-[#4b14d8] to-[#8d90ad] flex items-center justify-center overflow-hidden shrink-0 rounded-sm">
          <i class="ph ph-heart text-white text-[24px]" ></i>
        </div>
        <div class="flex flex-col min-w-0 hide-on-collapse">
          <span class="text-white font-medium truncate text-base mb-1">Liked Songs</span>
          <div class="flex items-center text-spotify-subdued text-sm gap-1">
            <i class="ph ph-push-pin text-spotify-green text-[14px]" ></i>
            <span class="truncate">Playlist • <%= typeof user !== 'undefined' && user ? user.name : '0 songs' %></span>
          </div>
        </div>
      </a>

      <!-- Data injected via Backend EJS -->
      <% 
        const roots = [];
        const childrenMap = {};
        if (typeof playlists !== 'undefined' && playlists.length > 0) {
          playlists.forEach(item => {
            if (item.parentId) {
              if (!childrenMap[item.parentId]) childrenMap[item.parentId] = [];
              childrenMap[item.parentId].push(item);
            } else {
              roots.push(item);
            }
          });
        }
      %>
      <% if (roots.length > 0) { %>
        <% roots.forEach(item => { %>
          <% if (item.sidebarType === 'playlist' && item.isFolder) { %>
            <!-- Folder -->
            <div class="library-folder-container">
              <div class="library-item nav-item flex items-center justify-between p-2 rounded-md hover:bg-[#1a1a1a] transition-colors cursor-pointer center-on-collapse folder-toggle" data-id="<%= item.id %>">
                <div class="flex items-center gap-3 min-w-0">
                  <div class="w-12 h-12 bg-spotify-card-hover flex items-center justify-center overflow-hidden shrink-0 rounded-sm">
                    <i class="ph ph-folder-simple text-[#7f7f7f] text-[24px]"></i>
                  </div>
                  <div class="flex flex-col min-w-0 hide-on-collapse">
                    <span class="text-white font-medium truncate text-base mb-1"><%= item.title %></span>
                    <div class="flex items-center text-spotify-subdued text-sm gap-1">
                      <span class="truncate">Folder • <%= item.creator ? item.creator.name : '' %></span>
                    </div>
                  </div>
                </div>
                <i class="ph ph-caret-down text-spotify-subdued hide-on-collapse folder-icon-<%= item.id %> transition-transform"></i>
              </div>
              <div class="folder-content-<%= item.id %> hidden flex-col pl-4 border-l border-white/10 ml-4 mt-1">
                <% if (childrenMap[item.id]) { %>
                  <% childrenMap[item.id].forEach(child => { %>
                    <% let href = `/playlist/${child.itemId || child.id}` %>
                    <a href="<%= href %>" data-type="playlist" class="library-item nav-item flex items-center gap-3 p-2 rounded-md hover:bg-[#1a1a1a] transition-colors cursor-pointer center-on-collapse">
                      <div class="w-12 h-12 bg-spotify-card-hover flex items-center justify-center overflow-hidden shrink-0 rounded-sm">
                        <% if (child.cover || child.coverUrl) { %>
                          <img src="<%= child.cover || child.coverUrl %>" class="w-full h-full object-cover">
                        <% } else { %>
                          <i class="ph ph-music-note text-[#7f7f7f] text-[24px]"></i>
                        <% } %>
                      </div>
                      <div class="flex flex-col min-w-0 hide-on-collapse">
                        <span class="text-white font-medium truncate text-base mb-1"><%= child.title %></span>
                        <div class="flex items-center text-spotify-subdued text-sm gap-1">
                          <span class="truncate">Playlist • <%= child.creator ? child.creator.name : '' %></span>
                        </div>
                      </div>
                    </a>
                  <% }) %>
                <% } %>
              </div>
            </div>
          <% } else { %>
            <!-- Standalone item (Playlist, Artist, Podcast) -->
            <% let href = item.sidebarType === 'playlist' ? `/playlist/${item.itemId || item.id}` : (item.sidebarType === 'artist' ? `/artist/${encodeURIComponent(item.title)}` : `/podcast/${item.itemId}`) %>
            <% let isArtist = item.sidebarType === 'artist' %>
            <a href="<%= href %>" data-type="<%= item.sidebarType %>" class="library-item nav-item flex items-center gap-3 p-2 rounded-md hover:bg-[#1a1a1a] transition-colors cursor-pointer center-on-collapse">
              <div class="w-12 h-12 bg-spotify-card-hover flex items-center justify-center overflow-hidden shrink-0 <%= isArtist ? 'rounded-full' : 'rounded-sm' %>">
                <% const sidebarImg = (isArtist && item.user && item.user.avatar) ? item.user.avatar : (item.cover || item.coverUrl); %>
                <% if (sidebarImg) { %>
                  <img src="<%= sidebarImg %>" class="w-full h-full object-cover">
                <% } else { %>
                  <i class="ph <%= isArtist ? 'person' : 'music_note' %> text-[#7f7f7f] <%= isArtist ? 'text-[24px]' : 'text-[24px]' %>"></i>
                <% } %>
              </div>
              <div class="flex flex-col min-w-0 hide-on-collapse">
                <span class="text-white font-medium truncate text-base mb-1"><%= item.title %></span>
                <div class="flex items-center text-spotify-subdued text-sm gap-1">
                  <% if (item.sidebarType === 'playlist' && item.creator) { %>
                    <span class="truncate">Playlist • <%= item.creator.name %></span>
                  <% } else { %>
                    <span class="capitalize truncate"><%= item.sidebarType %></span>
                  <% } %>
                </div>
              </div>
            </a>
          <% } %>
        <% }) %>
      <% } else { %>
        <!-- Empty state placeholder if needed -->
      <% } %>
    </div>
  </div>
</div>
