<aside class="sidebar-right">
  <div class="now-playing-context">
    <h3>Now Playing</h3>
    <img id="context-cover" src="https://picsum.photos/seed/context/200/200" alt="Cover">
    <h4 id="context-title">Select a track</h4>
    <p id="context-artist">Artist Info</p>
    
    <% if (user.role === 'free') { %>
      <div class="ad-banner">
        <p><strong>Go Premium!</strong></p>
        <p>Listen without limits and access exclusive content.</p>
        <a href="/switch-role/premium" class="btn btn-primary">Upgrade Now</a>
      </div>
    <% } else { %>
      <div class="premium-badge">
        <i class="fas fa-crown"></i> Premium Member
      </div>
    <% } %>
  </div>
</aside>
