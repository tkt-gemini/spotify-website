<div class="flex flex-col h-full bg-spotify-black p-4 [.is-collapsed_&]:hidden">
  <!-- NOW PLAYING VIEW -->
  <div id="now-playing-view" class="flex flex-col h-full">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-white font-bold text-base hover:underline cursor-pointer">Now Playing</h2>
      <div class="flex gap-2 text-spotify-subdued">
        <button id="close-right-sidebar" class="shrink-0 w-8 h-8 flex items-center justify-center hover:text-white hover:bg-spotify-elevated rounded-full transition-colors" title="Close">
          <i class="ph ph-x text-[20px]"></i>
        </button>
      </div>
    </div>

    <div class="flex flex-col items-start mt-2">
      <!-- Album Art Placeholder -->
      <div class="w-full aspect-square bg-spotify-card-hover rounded-md shadow-lg flex items-center justify-center mb-4 group cursor-pointer relative overflow-hidden">
        <i class="ph ph-music-note text-[64px] text-spotify-black"></i>
      </div>
      
      <!-- Track Info -->
      <div class="flex justify-between items-center w-full mb-6">
        <div class="flex flex-col overflow-hidden">
          <a href="#" class="text-white font-bold text-2xl hover:underline truncate">Song Title</a>
          <a href="#" class="text-spotify-subdued text-base font-medium hover:underline hover:text-white truncate">Artist Name</a>
        </div>
        <button id="right-sidebar-favorite" class="text-spotify-subdued hover:text-white transition-colors shrink-0 btn-like-track">
          <i class="ph ph-heart text-[24px]"></i>
        </button>
      </div>
      
      <!-- Artist About Section Placeholder -->
      <div class="w-full bg-spotify-elevated rounded-lg p-4 mt-2 relative overflow-hidden cursor-pointer group">
        <div class="absolute inset-0 bg-spotify-elevated-hover opacity-0 group-hover:opacity-10 transition-opacity"></div>
        <h3 class="text-white font-bold text-sm mb-2 relative z-10">About the artist</h3>
        <div class="w-16 h-16 rounded-full bg-spotify-black flex items-center justify-center mb-3">
          <i class="ph ph-user text-gray-500"></i>
        </div>
        <a href="#" class="text-white font-bold hover:underline mb-1 inline-block">Artist Name</a>
        <p class="text-spotify-subdued text-sm font-medium line-clamp-3">
          Detailed artist biography and information goes here. This section updates when a new song is played.
        </p>
      </div>
    </div>
  </div>

  <!-- QUEUE VIEW -->
  <div id="queue-view" class="flex flex-col h-full hidden">
    <div class="flex items-center justify-between mb-6 shrink-0">
      <h2 class="text-white font-bold text-base hover:underline cursor-pointer">Queue</h2>
      <div class="flex gap-2 text-spotify-subdued">
        <button id="close-queue-sidebar" class="shrink-0 w-8 h-8 flex items-center justify-center hover:text-white hover:bg-spotify-elevated rounded-full transition-colors" title="Close">
          <i class="ph ph-x text-[20px]"></i>
        </button>
      </div>
    </div>
    
    <div class="flex-1 overflow-y-auto pr-2 pb-10">
      <h3 class="text-white font-bold text-sm mb-2">Now Playing</h3>
      <div id="queue-current-track" class="flex items-center gap-3 p-2 hover:bg-spotify-elevated rounded-md cursor-pointer transition-colors group mb-6">
        <div class="w-10 h-10 bg-spotify-card-hover rounded shrink-0 flex items-center justify-center overflow-hidden">
          <i class="ph ph-music-note text-gray-500 text-sm"></i>
        </div>
        <div class="flex flex-col min-w-0">
          <span class="text-spotify-green text-sm font-medium truncate">No track playing</span>
          <span class="text-spotify-subdued text-xs truncate">-</span>
        </div>
      </div>

      <div id="queue-next-tracks" class="flex flex-col gap-2">
        <p class="text-spotify-subdued text-sm px-2">No tracks in queue.</p>
      </div>
    </div>
  </div>
</div>

<!-- COLLAPSED VIEW (Only visible when is-collapsed) -->
<div class="hidden [.is-collapsed_&]:flex flex-col items-center justify-center h-full cursor-pointer hover:bg-white/5 transition-colors" id="right-sidebar-collapsed-btn" title="Expand Now Playing">
  <i class="ph ph-caret-left text-spotify-subdued hover:text-white transition-colors text-[32px]"></i>
</div>
