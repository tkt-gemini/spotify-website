<div class="flex items-center justify-between w-full h-full text-spotify-subdued">
  
  <!-- Left: Track Info -->
  <div class="w-[30%] min-w-[180px] flex items-center justify-start gap-4">
    <!-- Image -->
    <div class="w-14 h-14 bg-spotify-elevated rounded flex items-center justify-center overflow-hidden shrink-0 shadow-md">
      <i class="ph ph-music-note text-gray-500"></i>
    </div>
    <!-- Title and Artist -->
    <div class="flex flex-col justify-center min-w-0 pr-4">
      <a href="#" id="playback-track-title" class="text-white text-sm font-medium hover:underline truncate">No Track Playing</a>
      <a href="#" id="playback-track-artist" class="text-xs hover:underline hover:text-white truncate">Select a track to play</a>
    </div>
    <!-- Like icon -->
    <button id="playback-bar-favorite" class="hover:text-white transition-colors flex items-center shrink-0 btn-like-track">
      <i class="ph ph-heart text-base"></i>
    </button>
  </div>

  <!-- Center: Playback Controls -->
  <div class="w-[40%] max-w-[722px] flex flex-col items-center justify-center gap-1">
    <!-- Buttons -->
    <div class="flex items-center gap-4">
      <button id="btn-shuffle" class="hover:text-white transition-colors flex items-center">
        <i class="ph ph-shuffle text-[20px]"></i>
      </button>
      <button id="btn-prev" class="hover:text-white transition-colors flex items-center">
        <i class="ph-fill ph-skip-back text-[20px]" ></i>
      </button>
      <button id="main-play-btn-container" class="w-8 h-8 rounded-full bg-white text-black flex items-center justify-center hover:scale-105 transition-transform shrink-0 outline-none focus:outline-none">
        <i id="main-play-btn" class="ph-fill ph-play text-[16px]" ></i>
      </button>
      <button id="btn-next" class="hover:text-white transition-colors flex items-center">
        <i class="ph-fill ph-skip-forward text-[20px]" ></i>
      </button>
      <button id="btn-repeat" class="hover:text-white transition-colors flex items-center">
        <i class="ph ph-repeat text-[20px]"></i>
      </button>
    </div>
    <!-- Progress Bar -->
    <div class="flex items-center gap-2 w-full max-w-[600px] text-xs font-medium">
      <span id="playback-current-time" class="w-10 text-right">0:00</span>
      <div id="progress-bar-container" class="flex-1 h-1 bg-[#4d4d4d] rounded-full group cursor-pointer relative flex items-center">
        <!-- Progress fill -->
        <div id="playback-progress-bar" class="h-full bg-white rounded-full group-hover:bg-spotify-green transition-colors absolute left-0 top-0" style="width: 0%;"></div>
        <!-- Handle -->
        <div id="playback-progress-handle" class="w-3 h-3 bg-white rounded-full absolute top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 shadow" style="left: 0%; transform: translate(-50%, -50%);"></div>
      </div>
      <span id="playback-duration" class="w-10 text-left">0:00</span>
    </div>
  </div>

  <!-- Right: Extra Controls -->
  <div class="w-[30%] min-w-[180px] flex items-center justify-end gap-3">
    <button id="lyrics-btn" class="hover:text-white transition-colors flex items-center" title="Lyrics">
      <i class="ph ph-microphone-stage text-[18px]"></i>
    </button>
    <button id="queue-btn" class="hover:text-white transition-colors flex items-center" title="Queue">
      <i class="ph ph-list-plus text-[18px]"></i>
    </button>
    
    <!-- Volume -->
    <div class="flex items-center gap-2 group w-24">
      <button id="volume-mute-btn" class="hover:text-white transition-colors flex items-center outline-none focus:outline-none" title="Mute">
        <i id="volume-icon" class="ph ph-speaker-high text-[18px]"></i>
      </button>
      <div id="volume-slider-container" class="flex-1 h-1 bg-[#4d4d4d] rounded-full cursor-pointer relative flex items-center group-hover:bg-[#535353]">
        <div id="volume-slider-fill" class="h-full bg-white rounded-full group-hover:bg-spotify-green transition-colors absolute left-0 top-0" style="width: 100%;"></div>
        <div id="volume-slider-handle" class="w-3 h-3 bg-white rounded-full absolute top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 shadow" style="left: 100%; transform: translate(-50%, -50%);"></div>
      </div>
    </div>
    
    <button id="fullscreen-btn" class="hover:text-white transition-colors flex items-center" title="Full screen">
      <i class="ph ph-corners-out text-[18px]"></i>
    </button>
  </div>
</div>
