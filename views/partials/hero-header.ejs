<% 
  // Default variables if not provided
  const _cover = typeof cover !== 'undefined' ? cover : null;
  const _icon = typeof icon !== 'undefined' ? icon : 'music_note';
  const _gradientFrom = typeof gradientFrom !== 'undefined' ? gradientFrom : '#5a3a3a';
  const _gradientTo = typeof gradientTo !== 'undefined' ? gradientTo : '#121212';
  const _type = typeof type !== 'undefined' ? type : 'Playlist';
  const _title = typeof title !== 'undefined' ? title : 'Unknown';
  const _description = typeof description !== 'undefined' ? description : null;
  const _creator = typeof creator !== 'undefined' ? creator : null;
  const _metaText = typeof metaText !== 'undefined' ? metaText : '';
  const _isEditable = typeof isEditable !== 'undefined' ? isEditable : false;
  const _titleEditTooltip = typeof titleEditTooltip !== 'undefined' ? titleEditTooltip : 'Click to edit details';
  const _editCoverId = typeof editCoverId !== 'undefined' ? editCoverId : 'edit-cover-trigger-img';
%>

<!-- Dynamic Gradient Background -->
<div class="absolute top-0 left-0 w-full h-[400px] z-0 pointer-events-none transition-colors duration-500" 
     style="background: linear-gradient(180deg, <%= _gradientFrom %> 0%, <%= _gradientTo %> 100%);">
</div>

<!-- Header Section -->
<div class="relative z-10 flex flex-col justify-end p-6 pt-24 min-h-[340px]">
  <div class="flex items-end gap-6">
    <div class="w-48 h-48 sm:w-52 sm:h-52 md:w-60 md:h-60 rounded shadow-2xl overflow-hidden flex items-center justify-center shrink-0 bg-spotify-card-hover group relative">
      <% if (_cover) { %>
        <img id="hero-cover-display" src="<%= _cover %>" class="w-full h-full object-cover">
      <% } else { %>
        <i class="ph <%= _icon %> text-[#7f7f7f] text-[80px]" ></i>
      <% } %>
      
      <% if (_isEditable) { %>
        <div id="<%= _editCoverId %>" class="absolute inset-0 bg-black/60 flex-col items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer flex">
          <i class="ph ph-pencil-simple text-[48px] mb-2"></i>
          <span class="font-bold text-sm">Choose photo</span>
        </div>
      <% } %>
    </div>

    <div class="flex flex-col justify-end w-full">
      <span class="text-sm font-bold text-white tracking-wider mb-2 uppercase drop-shadow-md"><%= _type %></span>
      
      <h1 id="hero-title-display" class="text-white font-black text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl leading-none tracking-tighter mb-4 <%= _isEditable ? 'cursor-pointer hover:underline' : '' %> w-full truncate drop-shadow-xl" style="word-break: break-word;" <%= _isEditable ? `title="${_titleEditTooltip}"` : '' %>>
        <%= _title %>
      </h1>
      
      <% if (_description) { %>
        <p id="hero-description-display" class="text-spotify-subdued text-sm font-medium mb-3 mt-2 line-clamp-2"><%= _description %></p>
      <% } %>
      
      <div class="flex items-center gap-1 text-sm text-white font-bold mt-2 flex-wrap">
        <% if (_creator) { %>
          <% if (_creator.id) { %>
            <a href="/user/<%= _creator.id %>" class="w-6 h-6 rounded-full bg-spotify-card-hover flex items-center justify-center overflow-hidden mr-1 hover:opacity-80 transition-opacity">
              <% if (_creator.avatar) { %>
                <img src="<%= _creator.avatar %>" alt="<%= _creator.name %>" class="w-full h-full object-cover">
              <% } else { %>
                <i class="ph ph-user text-xs text-gray-400"></i>
              <% } %>
            </a>
            <a href="/user/<%= _creator.id %>" class="hover:underline cursor-pointer"><%= _creator.name %></a>
          <% } else { %>
            <div class="w-6 h-6 rounded-full bg-spotify-card-hover flex items-center justify-center overflow-hidden mr-1">
              <% if (_creator.avatar) { %>
                <img src="<%= _creator.avatar %>" alt="<%= _creator.name %>" class="w-full h-full object-cover">
              <% } else { %>
                <i class="ph ph-user text-xs text-gray-400"></i>
              <% } %>
            </div>
            <span><%= _creator.name %></span>
          <% } %>
          <span class="before:content-['•'] before:mx-1 text-spotify-subdued font-medium"><%= _metaText %></span>
        <% } else { %>
          <span class="text-spotify-subdued font-medium"><%= _metaText %></span>
        <% } %>
      </div>
    </div>
  </div>
</div>
