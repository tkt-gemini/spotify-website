<%# Artist Studio Dashboard — /studio/artist ─── Data vars: profile{}, tracks[] %>
<div class="flex flex-col min-h-full w-full bg-spotify-black">

  <%# ── Header ───────────────────────────────────────────────────────────── %>
  <div class="relative overflow-hidden shrink-0">
    <div class="absolute inset-0" style="background: linear-gradient(135deg, #1a0d2e 0%, #121212 60%);"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 10% 80%, rgba(162,89,255,0.15) 0%, transparent 55%);"></div>
    <div class="relative z-10 px-8 pt-20 pb-8 flex items-end gap-4">
      <a href="/studio" class="text-[#a7a7a7] hover:text-white text-sm font-semibold flex items-center gap-1 mb-1 transition-colors">
        <i class="ph ph-caret-left text-lg"></i>
        Studio
      </a>
      <span class="text-[#a7a7a7] text-sm mb-1">/</span>
      <div>
        <p class="text-[#a259ff] text-xs font-bold uppercase tracking-[0.2em] mb-1">Artist Studio</p>
        <h1 class="text-white text-3xl font-black tracking-tight" id="sa-title-display">
          <% if (typeof profile !== 'undefined' && profile) { %>
            <%= profile.name %>
          <% } else { %>
            Artist Profile
          <% } %>
        </h1>
      </div>
      <% if (typeof profile !== 'undefined' && profile) { %>
        <div class="ml-auto">
          <a href="/artist/<%= profile.name %>" target="_blank" id="sa-view-public-link"
            class="flex items-center gap-2 px-4 py-2 border border-white/20 hover:border-white text-white text-sm font-semibold rounded-full transition-colors">
            <i class="ph ph-arrow-square-out text-base"></i> View Public
          </a>
        </div>
      <% } %>
    </div>
  </div>

  <div class="px-8 py-6 flex-1 overflow-y-auto">
    <% if (typeof profile === 'undefined' || !profile) { %>
      <%# ── Not registered ──────────────────────────────────────────────── %>
      <div class="flex flex-col items-center justify-center py-24 text-center">
        <div class="w-24 h-24 rounded-full bg-[#282828] flex items-center justify-center mb-6"
             style="background: linear-gradient(135deg, #a259ff22, #28282888);">
          <i class="ph ph-music-note text-[#a259ff] text-5xl"></i>
        </div>
        <h2 class="text-white text-2xl font-bold mb-3">You're not registered as an artist</h2>
        <p class="text-[#a7a7a7] text-sm mb-6 max-w-xs">Get started to manage your artist profile and showcase your music on Spotify.</p>
        <button id="sa-register-btn"
          class="flex items-center gap-2 px-6 py-3 font-bold text-sm text-white rounded-full transition-colors border border-[#a259ff] hover:bg-[#a259ff]"
          onclick="window.studioRegisterArtist()">
          <i class="ph ph-music-note"></i>
          Get Started as Artist
        </button>
      </div>

    <% } else { %>
      <%# ── Profile editor ──────────────────────────────────────────────── %>
      <div class="grid gap-8" style="grid-template-columns: 1fr 1.5fr;">

        <%# Left: Avatar + quick stats %>
        <div class="flex flex-col gap-6">
          <%# Avatar card %>
          <div class="bg-white/5 backdrop-blur-xl rounded-3xl p-8 border border-white/10 shadow-lg">
            <h3 class="text-white font-bold mb-6 text-lg">Profile Image</h3>
            <div id="sa-avatar-area"
              class="relative w-40 h-40 rounded-full bg-[#282828] overflow-hidden cursor-pointer mx-auto mb-4 group shadow-[0_0_30px_rgba(0,0,0,0.5)] border-4 border-white/10 transition-transform duration-300 hover:scale-105">
              <% if (profile.avatar) { %>
                <img id="sa-avatar-preview" src="<%= profile.avatar %>" class="w-full h-full object-cover">
              <% } else { %>
                <img id="sa-avatar-preview" src="" class="hidden w-full h-full object-cover">
                <div id="sa-avatar-placeholder" class="w-full h-full flex items-center justify-center">
                  <i class="ph ph-user text-[#727272] text-6xl"></i>
                </div>
              <% } %>
              <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 flex flex-col items-center justify-center transition-opacity">
                <i class="ph ph-pencil-simple text-white text-3xl mb-1"></i>
                <span class="text-white text-xs font-semibold">Change photo</span>
              </div>
              <input type="file" id="sa-avatar-input" accept=".jpg,.jpeg,.png,.webp" class="hidden">
            </div>
            <p class="text-[#727272] text-xs text-center">JPG, PNG or WebP · Max 5MB</p>
          </div>

          <%# Cover image card %>
          <div class="bg-white/5 backdrop-blur-xl rounded-3xl p-8 border border-white/10 shadow-lg">
            <h3 class="text-white font-bold mb-6 text-lg">Cover Image</h3>
            <div id="sa-cover-area"
              class="relative w-full aspect-video rounded-2xl bg-[#282828] overflow-hidden cursor-pointer group shadow-[0_0_30px_rgba(0,0,0,0.5)] border border-white/10 transition-transform duration-300 hover:scale-105">
              <% if (profile.coverImage) { %>
                <img id="sa-cover-preview" src="<%= profile.coverImage %>" class="w-full h-full object-cover">
              <% } else { %>
                <img id="sa-cover-preview" src="" class="hidden w-full h-full object-cover">
                <div id="sa-cover-placeholder" class="w-full h-full flex flex-col items-center justify-center gap-2">
                  <i class="ph ph-image text-[#727272] text-3xl"></i>
                  <span class="text-[#727272] text-xs">Add cover image</span>
                </div>
              <% } %>
              <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 flex items-center justify-center transition-opacity">
                <span class="text-white text-sm font-semibold">Change cover</span>
              </div>
              <input type="file" id="sa-cover-input" accept=".jpg,.jpeg,.png,.webp" class="hidden">
            </div>
            <p class="text-[#727272] text-xs mt-2">JPG, PNG or WebP · Max 5MB</p>
          </div>
        </div>

        <%# Right: Bio + Name form %>
        <div class="flex flex-col gap-6">
          <div class="bg-white/5 backdrop-blur-xl rounded-3xl p-8 border border-white/10 shadow-lg">
            <h3 class="text-white font-bold mb-6 text-lg">Profile Details</h3>

            <div class="flex flex-col gap-4">
              <div class="flex flex-col gap-1">
                <label class="text-xs font-bold text-[#a7a7a7] uppercase tracking-wider">Artist Name</label>
                <input type="text" id="sa-name-input" value="<%= profile.name %>"
                  class="bg-white/5 border border-white/10 focus:border-[#a259ff] focus:bg-white/10 focus:shadow-[0_0_15px_rgba(162,89,255,0.3)] text-white text-sm rounded-xl px-4 py-3 outline-none transition-all duration-300"
                  placeholder="Your artist name" maxlength="100">
              </div>

              <div class="flex flex-col gap-1">
                <label class="text-xs font-bold text-[#a7a7a7] uppercase tracking-wider">Bio</label>
                <textarea id="sa-bio-input" rows="6"
                  class="bg-white/5 border border-white/10 focus:border-[#a259ff] focus:bg-white/10 focus:shadow-[0_0_15px_rgba(162,89,255,0.3)] text-white text-sm rounded-xl px-4 py-3 outline-none resize-none transition-all duration-300"
                  placeholder="Tell listeners about yourself..." maxlength="1000"><%= profile.bio || '' %></textarea>
                <p class="text-[#727272] text-xs text-right" id="sa-bio-count"><%= (profile.bio || '').length %>/1000</p>
              </div>

              <div class="flex justify-end pt-2">
                <button id="sa-save-btn"
                  class="px-8 py-3 rounded-full font-bold text-sm text-black transition-all duration-300 shadow-[0_0_15px_rgba(162,89,255,0.4)] hover:shadow-[0_0_25px_rgba(162,89,255,0.7)]"
                  style="background: #a259ff;"
                  onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
                  Save Profile
                </button>
              </div>
            </div>
          </div>

          <%# Analytics %>
          <div class="grid grid-cols-2 gap-4 mt-6">
            <div class="bg-white/5 backdrop-blur-xl rounded-2xl p-6 border border-white/10 shadow-lg">
              <p class="text-[#a7a7a7] text-xs font-semibold uppercase tracking-wider mb-2">Monthly Listeners</p>
              <p class="text-white text-4xl font-black"><%= typeof stats !== 'undefined' && stats ? stats.monthlyListeners.toLocaleString() : '0' %></p>
              <p class="text-[#727272] text-xs mt-1">Last 30 days</p>
            </div>
            <div class="bg-white/5 backdrop-blur-xl rounded-2xl p-6 border border-white/10 shadow-lg">
              <p class="text-[#a7a7a7] text-xs font-semibold uppercase tracking-wider mb-2">Followers</p>
              <p class="text-white text-4xl font-black"><%= typeof stats !== 'undefined' && stats ? stats.followersCount.toLocaleString() : '0' %></p>
              <p class="text-[#727272] text-xs mt-1">All time</p>
            </div>
          </div>

          <%# Albums list %>
          <div class="bg-white/5 backdrop-blur-xl rounded-3xl p-8 border border-white/10 shadow-lg mt-6">
            <div class="flex items-center justify-between mb-6">
              <h3 class="text-white font-bold text-lg">Your Albums
                <span class="text-[#a7a7a7] font-normal text-sm ml-2">(<%= typeof albums !== 'undefined' && albums ? albums.length : 0 %>)</span>
              </h3>
              <button id="sa-create-album-btn" class="flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-semibold rounded-full transition-colors">
                <i class="ph ph-plus text-sm"></i> Create Album
              </button>
            </div>
            <% if (typeof albums !== 'undefined' && albums && albums.length > 0) { %>
              <div class="flex flex-col gap-2 max-h-64 overflow-y-auto custom-scrollbar">
                <% albums.forEach(a => { %>
                  <div class="flex items-center gap-3 p-2 hover:bg-white/5 rounded-lg transition-colors group relative cursor-pointer sa-edit-album-btn"
                       data-id="<%= a.id %>" data-title="<%= a.title %>" data-date="<%= a.releaseDate %>" data-type="<%= a.type %>" data-cover="<%= a.cover || '' %>">
                    <div class="w-12 h-12 rounded bg-[#282828] shrink-0 overflow-hidden shadow">
                      <% if (a.cover) { %>
                        <img src="<%= a.cover %>" class="w-full h-full object-cover">
                      <% } else { %>
                        <div class="w-full h-full flex items-center justify-center">
                          <i class="ph ph-record text-[#727272] text-xl"></i>
                        </div>
                      <% } %>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-white text-sm font-semibold truncate"><%= a.title %></p>
                      <p class="text-[#a7a7a7] text-xs capitalize"><%= a.type %> · <%= new Date(a.releaseDate).getFullYear() %></p>
                    </div>
                    <div class="opacity-0 group-hover:opacity-100 flex items-center gap-2">
                      <button class="text-[#a7a7a7] hover:text-white transition-colors" title="Edit">
                        <i class="ph ph-pencil-simple text-lg"></i>
                      </button>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="flex flex-col items-center justify-center py-6">
                <i class="ph ph-record text-[#727272] text-3xl mb-2"></i>
                <p class="text-[#a7a7a7] text-sm text-center">No albums yet. Group your tracks into albums or EPs.</p>
              </div>
            <% } %>
          </div>

          <%# Tracks list (read-only) %>
          <% if (typeof tracks !== 'undefined' && tracks && tracks.length > 0) { %>
            <div class="bg-white/5 backdrop-blur-xl rounded-3xl p-8 border border-white/10 shadow-lg mt-6">
              <div class="flex items-center justify-between mb-6">
                <h3 class="text-white font-bold text-lg">Your Tracks
                  <span class="text-[#a7a7a7] font-normal text-sm ml-2">(<%= tracks.length %>)</span>
                </h3>
                <button id="sa-upload-track-btn" class="flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-white/20 text-white text-sm font-semibold rounded-full transition-colors">
                  <i class="ph ph-upload-simple text-sm"></i> Upload Track
                </button>
              </div>
              <div class="flex flex-col gap-2 max-h-64 overflow-y-auto custom-scrollbar">
                <% tracks.forEach(t => { %>
                  <div class="flex items-center gap-3 p-2 hover:bg-white/5 rounded-lg transition-colors group relative cursor-pointer sa-edit-track-btn"
                       data-id="<%= t.id %>" data-title="<%= t.title %>" data-album="<%= t.albumId || '' %>" data-lyrics="<%= t.lyrics || '' %>">
                    <div class="w-10 h-10 rounded bg-[#282828] shrink-0 overflow-hidden">
                      <% if (t.cover) { %>
                        <img src="<%= t.cover %>" class="w-full h-full object-cover">
                      <% } else { %>
                        <div class="w-full h-full flex items-center justify-center">
                          <i class="ph ph-music-note text-[#727272] text-lg"></i>
                        </div>
                      <% } %>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-white text-sm font-semibold truncate"><%= t.title %></p>
                      <p class="text-[#a7a7a7] text-xs"><%= t.playCount || 0 %> plays</p>
                    </div>
                    <div class="opacity-0 group-hover:opacity-100 flex items-center gap-2">
                      <button class="text-[#a7a7a7] hover:text-white transition-colors" title="Edit">
                        <i class="ph ph-pencil-simple text-lg"></i>
                      </button>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          <% } else { %>
            <div class="bg-white/5 backdrop-blur-xl rounded-3xl p-8 border border-white/10 shadow-lg mt-6">
              <div class="flex flex-col items-center justify-center text-center py-8">
                <div class="w-16 h-16 bg-[#282828] rounded-full flex items-center justify-center mb-4">
                  <i class="ph ph-music-note text-[#a259ff] text-3xl"></i>
                </div>
                <h3 class="text-white font-bold text-lg mb-2">Upload your first track</h3>
                <p class="text-[#a7a7a7] text-sm mb-6 max-w-xs">Share your music with the world. Uploading is fast, free, and instantly available to listeners.</p>
                <button id="sa-upload-track-btn-empty" class="px-6 py-3 font-bold text-sm text-black rounded-full transition-transform hover:scale-105" style="background: #a259ff;">
                  Upload Track
                </button>
              </div>
            </div>
          <% } %>
        </div>
      </div>

    <% } %>
  </div>
</div>
