<div class="flex flex-col min-h-full w-full bg-spotify-black relative overflow-x-hidden">
  <!-- Dynamic Gradient Background (Generative based on username length or ID to have unique colors) -->
  <% 
    const hash = profileUser.name.split('').reduce((acc, char) => acc + char.charCodeAt(0), 0);
    const hues = [220, 280, 320, 160, 40, 0];
    const hue = hues[hash % hues.length];
  %>
  <div class="absolute top-0 left-0 w-full h-[500px] z-0 pointer-events-none"
       style="background: linear-gradient(180deg, hsl(<%= hue %>, 50%, 30%) 0%, hsl(<%= hue %>, 50%, 15%) 40%, #121212 100%);">
  </div>

  <!-- Header Section -->
  <div class="relative z-10 flex flex-col justify-end px-8 pt-32 pb-8 min-h-[400px]">
    <div class="flex flex-col md:flex-row items-start md:items-end gap-6">
      <!-- Profile Avatar -->
      <div <%- (typeof isOwnProfile !== 'undefined' && isOwnProfile) ? 'id="edit-profile-trigger-avatar"' : '' %> 
           class="w-48 h-48 md:w-56 md:h-56 rounded-full shadow-2xl overflow-hidden shrink-0 bg-spotify-card-hover flex items-center justify-center relative group <%- (typeof isOwnProfile !== 'undefined' && isOwnProfile) ? 'cursor-pointer' : '' %> border-4 border-black/20" 
           data-current-name="<%= typeof profileUser !== 'undefined' && profileUser ? profileUser.name : '' %>" 
           data-current-avatar="<%= typeof profileUser !== 'undefined' && profileUser && profileUser.avatar ? profileUser.avatar : '' %>">
        
        <!-- Render container for JS replacement -->
        <div id="profile-avatar-container" class="w-full h-full flex items-center justify-center pointer-events-none">
          <% if (typeof profileUser !== 'undefined' && profileUser && profileUser.avatar) { %>
            <img src="<%= profileUser.avatar %>" class="w-full h-full object-cover">
          <% } else { %>
            <i class="ph ph-user text-[#7f7f7f] text-[80px]"></i>
          <% } %>
        </div>
        
        <!-- Hover Overlay for Avatar Edit -->
        <% if (typeof isOwnProfile !== 'undefined' && isOwnProfile) { %>
        <div class="absolute inset-0 bg-black/60 hidden group-hover:flex flex-col items-center justify-center cursor-pointer transition-opacity">
          <i class="ph ph-pencil-simple text-white text-4xl mb-2"></i>
          <span class="text-white font-semibold text-sm">Choose photo</span>
        </div>
        <% } %>
      </div>
      
      <!-- Profile Info -->
      <div class="flex flex-col text-white pb-2 w-full">
        <span class="text-sm font-bold tracking-wider mb-2 uppercase drop-shadow-md">Profile</span>
        <h1 <%- (typeof isOwnProfile !== 'undefined' && isOwnProfile) ? 'id="edit-profile-trigger-name"' : '' %> 
            class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-black mb-6 tracking-tighter leading-none w-full truncate drop-shadow-xl <%- (typeof isOwnProfile !== 'undefined' && isOwnProfile) ? 'cursor-pointer hover:underline' : '' %>" 
            data-current-name="<%= typeof profileUser !== 'undefined' && profileUser ? profileUser.name : '' %>" 
            data-current-avatar="<%= typeof profileUser !== 'undefined' && profileUser && profileUser.avatar ? profileUser.avatar : '' %>">
          <span id="profile-name-display"><%= typeof profileUser !== 'undefined' && profileUser ? profileUser.name : 'Unknown User' %></span>
        </h1>
        
        <div class="flex items-center text-sm font-medium text-white/90 gap-4">
          <span><%= userPlaylists ? userPlaylists.length : 0 %> Public Playlists</span>
          <span class="w-1 h-1 bg-white/50 rounded-full"></span>
          <span><%= typeof followedArtists !== 'undefined' ? followedArtists.length : 0 %> Following</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Content Section -->
  <div class="relative z-10 bg-black/20 flex-1 px-8 pb-12 w-full">
    <div class="absolute top-0 left-0 w-full h-60 bg-gradient-to-b from-black/40 to-transparent z-[-1] pointer-events-none"></div>

    <!-- Action Buttons -->
    <div class="flex items-center gap-6 py-6 w-full sticky top-0 z-20">
      <% if (userPlaylists && userPlaylists.length > 0) { %>
      <button class="w-14 h-14 bg-spotify-green hover:bg-spotify-green-hover hover:scale-105 rounded-full flex items-center justify-center transition-all duration-300 shadow-xl" onclick="window.location.href='/playlist/<%= userPlaylists[0].id %>'">
        <i class="ph-fill ph-play text-black text-2xl ml-[2px]" ></i>
      </button>
      <% } else { %>
      <button class="w-14 h-14 bg-white/10 text-white/40 rounded-full flex items-center justify-center cursor-not-allowed border border-white/5">
        <i class="ph-fill ph-play text-2xl ml-[2px]" ></i>
      </button>
      <% } %>
      
      <% if (typeof isOwnProfile !== 'undefined' && isOwnProfile) { %>
        <button class="px-5 py-2 rounded-full border border-[#727272] hover:border-white text-white text-sm font-bold tracking-widest uppercase hover:scale-105 transition-all" onclick="document.getElementById('edit-profile-trigger-avatar').click()">
          Edit Profile
        </button>
        <button onclick="window.location.href='/studio'" class="group relative px-6 py-2 rounded-full font-bold text-sm tracking-widest uppercase text-white shadow-lg border border-white/20 overflow-hidden hover:scale-105 transition-all">
          <div class="absolute inset-0 bg-gradient-to-r from-[#a259ff] to-[#1ed760] opacity-80 group-hover:opacity-100 transition-opacity"></div>
          <span class="relative z-10 flex items-center gap-2">
            <i class="ph ph-microphone text-[18px]"></i> Studio
          </span>
        </button>
      <% } else { %>
        <button class="text-spotify-subdued hover:text-white transition-colors active:scale-95" title="Copy Profile Link" onclick="window.copyToClipboard(window.location.href, 'Link copied to clipboard');">
          <i class="ph ph-dots-three text-[32px]"></i>
        </button>
      <% } %>
    </div>

    <!-- Public Playlists Section -->
    <% if (userPlaylists && userPlaylists.length > 0) { %>
    <div class="mt-8">
      <h2 class="text-2xl font-bold text-white hover:underline cursor-pointer inline-block mb-6">Public Playlists</h2>
      <div class="grid gap-6" style="grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));">
        <% userPlaylists.forEach(playlist => { %>
          <div class="bg-white/5 hover:bg-white/10 transition-colors p-4 rounded-xl cursor-pointer group" onclick="window.location.href='/playlist/<%= playlist.id %>'">
            <div class="relative w-full aspect-square mb-4 shadow-lg rounded-md overflow-hidden bg-spotify-elevated">
              <% if (playlist.cover) { %>
                <img src="<%= playlist.cover %>" class="w-full h-full object-cover">
              <% } else { %>
                <div class="w-full h-full flex items-center justify-center">
                  <i class="ph ph-music-note text-[#7f7f7f] text-[64px]"></i>
                </div>
              <% } %>
              <!-- Play Button overlay -->
              <div class="absolute bottom-2 right-2 translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
                <button class="w-12 h-12 bg-spotify-green hover:bg-spotify-green-hover rounded-full flex items-center justify-center shadow-xl hover:scale-105 transition-transform" onclick="event.stopPropagation(); window.location.href='/playlist/<%= playlist.id %>'">
                  <i class="ph-fill ph-play text-black text-2xl ml-[2px]" ></i>
                </button>
              </div>
            </div>
            <h3 class="text-white font-bold text-base truncate mb-1"><%= playlist.title %></h3>
            <p class="text-spotify-subdued text-sm truncate"><%= playlist.description || 'By ' + profileUser.name %></p>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- Following Artists Section -->
    <% if (typeof followedArtists !== 'undefined' && followedArtists.length > 0) { %>
    <div class="mt-12">
      <h2 class="text-2xl font-bold text-white hover:underline cursor-pointer inline-block mb-6">Following</h2>
      <div class="grid gap-6" style="grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));">
        <% followedArtists.forEach(artist => { %>
          <div class="bg-white/5 hover:bg-white/10 transition-colors p-4 rounded-xl cursor-pointer group" onclick="window.location.href='/artist/<%= encodeURIComponent(artist.name) %>'">
            <div class="relative w-full aspect-square mb-4 shadow-lg rounded-full overflow-hidden bg-spotify-elevated">
              <% const aImg = artist.avatar || (artist.user && artist.user.avatar) || null; %>
              <% if (aImg) { %>
                <img src="<%= aImg %>" class="w-full h-full object-cover">
              <% } else { %>
                <div class="w-full h-full flex items-center justify-center">
                  <i class="ph ph-user text-[#7f7f7f] text-[64px]"></i>
                </div>
              <% } %>
            </div>
            <h3 class="text-white font-bold text-base truncate mb-1 text-center"><%= artist.name %></h3>
            <p class="text-spotify-subdued text-sm truncate text-center capitalize">Artist</p>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- Following Podcasts Section -->
    <% if (typeof followedPodcasts !== 'undefined' && followedPodcasts.length > 0) { %>
    <div class="mt-12">
      <h2 class="text-2xl font-bold text-white hover:underline cursor-pointer inline-block mb-6">Podcasts</h2>
      <div class="grid gap-6" style="grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));">
        <% followedPodcasts.forEach(podcast => { %>
          <div class="bg-white/5 hover:bg-white/10 transition-colors p-4 rounded-xl cursor-pointer group" onclick="window.location.href='/podcast/<%= podcast.id %>'">
            <div class="relative w-full aspect-square mb-4 shadow-lg rounded-xl overflow-hidden bg-spotify-elevated">
              <% if (podcast.cover) { %>
                <img src="<%= podcast.cover %>" class="w-full h-full object-cover">
              <% } else { %>
                <div class="w-full h-full flex items-center justify-center">
                  <i class="ph ph-microphone text-[#7f7f7f] text-[64px]"></i>
                </div>
              <% } %>
            </div>
            <h3 class="text-white font-bold text-base truncate mb-1"><%= podcast.title %></h3>
            <p class="text-spotify-subdued text-sm truncate"><%= podcast.owner ? podcast.owner.name : 'Podcast' %></p>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

  </div>
</div>
