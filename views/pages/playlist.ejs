<div class="flex flex-col h-full relative z-10 w-full bg-spotify-black">
  <%- include('../partials/hero-header', {
    cover: playlist && playlist.cover ? playlist.cover : null,
    icon: 'music_note',
    gradientFrom: '#5a3a3a',
    gradientTo: '#121212',
    type: 'Playlist',
    title: playlist ? playlist.title : 'Unknown',
    description: playlist ? playlist.description : null,
    creator: playlist && playlist.creator ? { id: playlist.creatorId, name: playlist.creator.name, avatar: playlist.creator.avatar } : { name: 'Unknown User' },
    metaText: `${playlist && playlist.tracks ? playlist.tracks.length : 0} songs`,
    isEditable: typeof user !== 'undefined' && playlist && playlist.creatorId === user.id,
    titleEditTooltip: 'Click to edit details',
    editCoverId: 'edit-playlist-trigger-img'
  }) %>

  <!-- Action Bar & Tracklist -->
  <div class="relative z-10 bg-black/20 flex-1 px-6 pb-6 w-full">
    <div class="absolute top-0 left-0 w-full h-60 bg-gradient-to-b from-black/20 to-transparent z-[-1] pointer-events-none"></div>
    
    <!-- Action Row -->
    <div class="flex items-center gap-6 py-6 w-full sticky top-0 z-20">
      <% if (playlist && playlist.tracks && playlist.tracks.length > 0) { %>
      <button class="btn-play-lg group w-14 h-14 bg-spotify-green hover:bg-spotify-green-hover hover:scale-105 rounded-full flex items-center justify-center transition-all duration-300 shadow-xl"
              onclick="if(document.querySelector('.play-btn-icon')) { document.querySelector('.play-btn-icon').closest('button').click(); }">
        <i class="ph-fill ph-play text-black text-2xl ml-[2px]" ></i>
      </button>
      <% } else { %>
      <button class="w-14 h-14 bg-white/10 text-white/40 rounded-full flex items-center justify-center cursor-not-allowed border border-white/5">
        <i class="ph-fill ph-play text-2xl ml-[2px]" ></i>
      </button>
      <% } %>
      
      <% if (typeof user === 'undefined' || (playlist && playlist.creatorId !== user.id)) { %>
      <button id="btn-save-playlist" data-id="<%= playlist.id %>" data-title="<%= playlist.title.replace(/'/g, "\\'") %>" data-cover="<%= playlist.cover || '' %>" data-creator="<%= (playlist.creator && playlist.creator.name) ? playlist.creator.name.replace(/'/g, "\\'") : 'Unknown' %>" class="text-spotify-subdued hover:text-white transition-colors" title="Save to Your Library" onclick="toggleSavePlaylist(this)">
        <i class="<%= typeof isSaved !== 'undefined' && isSaved ? 'ph-fill ph-check-circle text-spotify-green' : 'ph ph-plus-circle' %> text-[36px]"></i>
      </button>
      <% } %>
      
      <button class="text-spotify-subdued hover:text-white transition-colors active:scale-95" title="Copy Playlist Link" onclick="window.copyToClipboard(window.location.href, 'Link copied to clipboard');">
        <i class="ph ph-link text-[32px]"></i>
      </button>
      
      <button class="text-spotify-subdued hover:text-white transition-colors active:scale-95 ml-2" title="More options" onclick="window.showToast('More options coming soon')">
        <i class="ph ph-dots-three text-[32px]"></i>
      </button>

      <% if (typeof user !== 'undefined' && playlist && playlist.creatorId === user.id) { %>
      <button id="delete-playlist-btn" data-id="<%= playlist.id %>" class="text-spotify-subdued hover:text-white transition-colors ml-auto flex items-center gap-1 text-sm font-bold">
        <i class="ph ph-trash text-[20px]"></i>
        Delete
      </button>
      <% } %>
    </div>

    <!-- Tracklist Table -->
    <%- include('../partials/track-list', {
      tracks: playlist && playlist.tracks ? playlist.tracks : [],
      contextName: playlist ? playlist.title : 'Playlist',
      playlistId: playlist ? playlist.id : null,
      showAlbum: true,
      showDateAdded: true,
      libraryItems: null
    }) %>

  </div>
</div>

<% if (typeof user !== 'undefined' && playlist && playlist.creatorId === user.id) { %>
<!-- Edit Playlist Modal -->
<div id="edit-playlist-modal" class="fixed inset-0 bg-black/70 flex items-center justify-center z-[100] hidden">
  <div class="bg-spotify-card-hover rounded-lg p-6 w-[524px] max-w-[90vw] flex flex-col shadow-2xl relative">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-white font-bold text-2xl">Edit details</h2>
      <button id="close-edit-modal-btn" class="w-8 h-8 rounded-full hover:bg-white/10 flex items-center justify-center text-spotify-subdued hover:text-white transition-colors">
        <i class="ph ph-x text-[24px]"></i>
      </button>
    </div>
    
    <div class="flex gap-4 mb-4">
      <!-- Image Upload Area -->
      <div class="w-48 h-48 bg-[#3E3E3E] rounded flex items-center justify-center shrink-0 relative group shadow-md cursor-pointer overflow-hidden" id="edit-cover-area">
        <% if (playlist.cover) { %>
          <img id="edit-cover-preview" src="<%= playlist.cover %>" class="w-full h-full object-cover">
        <% } else { %>
          <i id="edit-cover-placeholder" class="ph ph-music-note text-[#7f7f7f] text-[64px]"></i>
          <img id="edit-cover-preview" src="" class="w-full h-full object-cover hidden">
        <% } %>
        <div class="absolute inset-0 bg-black/60 flex-col items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-opacity flex">
          <i class="ph ph-pencil-simple text-[48px] mb-2"></i>
          <span class="font-bold text-sm">Choose photo</span>
        </div>
        <input type="file" id="cover-upload-input" accept="image/jpeg, image/png, image/webp" class="hidden">
      </div>
      
      <!-- Text Inputs -->
      <div class="flex flex-col flex-1 gap-4">
        <div class="flex flex-col relative bg-[#3E3E3E] rounded p-2 focus-within:bg-[#4E4E4E] border border-transparent focus-within:border-[#727272] transition-colors">
          <label class="text-xs font-bold text-white mb-1 px-1">Name</label>
          <input type="text" id="edit-title-input" value="<%= playlist.title %>" class="bg-transparent text-white text-sm outline-none px-1 h-8" placeholder="Add a name">
        </div>
        <!-- Optional Description -->
        <div class="flex flex-col relative bg-[#3E3E3E] rounded p-2 focus-within:bg-[#4E4E4E] border border-transparent focus-within:border-[#727272] transition-colors flex-1">
          <label class="text-xs font-bold text-white mb-1 px-1">Description</label>
          <textarea id="edit-desc-input" class="bg-transparent text-white text-sm outline-none px-1 resize-none h-full" placeholder="Add an optional description"><%= playlist.description || '' %></textarea>
        </div>

        <!-- Folder Dropdown -->
        <% if (typeof userFolders !== 'undefined' && userFolders.length > 0) { %>
        <div class="flex flex-col relative bg-[#3E3E3E] rounded p-2 focus-within:bg-[#4E4E4E] border border-transparent focus-within:border-[#727272] transition-colors">
          <label class="text-xs font-bold text-white mb-1 px-1">Add to folder (Optional)</label>
          <select id="edit-folder-input" class="bg-transparent text-white text-sm outline-none px-1 h-8 cursor-pointer">
            <option value="none" class="bg-[#282828] text-white">None</option>
            <% userFolders.forEach(f => { %>
              <!-- Prevent setting a folder as its own parent -->
              <% if (f.id !== playlist.id) { %>
                <option value="<%= f.id %>" class="bg-[#282828] text-white" <%= playlist.parentId === f.id ? 'selected' : '' %>><%= f.title %></option>
              <% } %>
            <% }) %>
          </select>
        </div>
        <% } %>
        
        <!-- Public Toggle -->
        <div class="flex items-center mt-3 px-1">
          <label class="relative flex items-center cursor-pointer group">
            <input type="checkbox" id="edit-public-input" class="peer sr-only" <%= playlist.isPublic ? 'checked' : '' %>>
            <!-- Checkbox Box -->
            <div class="w-[18px] h-[18px] shrink-0 rounded-[3px] border-[1.5px] border-[#a7a7a7] bg-transparent peer-checked:bg-spotify-green peer-checked:border-spotify-green transition-all group-hover:border-white relative overflow-hidden z-0"></div>
            <!-- Checkmark SVG -->
            <svg class="w-3 h-3 text-black absolute left-[3px] top-1/2 -translate-y-1/2 opacity-0 peer-checked:opacity-100 scale-50 peer-checked:scale-100 transition-all duration-200 ease-out z-10 pointer-events-none" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span class="ml-3 text-[#a7a7a7] group-hover:text-white text-sm font-semibold transition-colors">Set as public playlist</span>
          </label>
        </div>
      </div>
    </div>
    
    <div class="flex justify-end">
      <button id="save-playlist-btn" class="bg-white text-black font-bold px-8 py-3 rounded-full hover:scale-105 hover:bg-gray-100 transition-all text-sm" data-playlist-id="<%= playlist.id %>">
        Save
      </button>
    </div>
    <p class="text-[11px] text-white/50 mt-4 font-medium">By proceeding, you agree to give Spotify access to the image you choose to upload. Please make sure you have the right to upload the image.</p>
  </div>
</div>
<% } %>
