<div class="flex flex-col h-full w-full bg-spotify-black relative pb-8">
  <!-- Gradient -->
  <div class="absolute top-0 left-0 w-full h-80 bg-gradient-to-b from-[#333333] to-[#121212] z-0 pointer-events-none transition-colors duration-500"></div>

  <!-- Content -->
  <div class="relative z-10 px-6 pt-24">
    <!-- Filter Chips -->
    <div class="flex gap-2 mb-8 flex-wrap items-center" id="home-filters">
      <a href="/" class="nav-item px-4 py-1.5 rounded-full text-sm font-medium transition-colors <%= currentFacet === 'all' ? 'bg-white text-black shadow-md' : 'bg-spotify-elevated hover:bg-spotify-elevated-hover text-white' %>">All</a>
      
      <!-- Music Control -->
      <% if (currentFacet === 'music' || currentFacet === 'music-artists' || currentFacet === 'music-songs') { %>
        <!-- Grouped Music Control (Active State) -->
        <div class="flex items-center bg-spotify-elevated rounded-full p-1 mx-1 border border-white/5">
          <a href="/?facet=music-artists" class="nav-item px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200 <%= currentFacet === 'music-artists' ? 'bg-white text-black shadow-md scale-100' : 'text-spotify-subdued hover:text-white hover:bg-white/10' %>">Artists</a>
          <a href="/?facet=music-songs" class="nav-item px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200 <%= currentFacet === 'music-songs' ? 'bg-white text-black shadow-md scale-100' : 'text-spotify-subdued hover:text-white hover:bg-white/10' %>">Songs</a>
        </div>
      <% } else { %>
        <!-- Standard Music Chip (Inactive State) -->
        <a href="/?facet=music-songs" class="nav-item px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-spotify-elevated hover:bg-spotify-elevated-hover text-white">Music</a>
      <% } %>

      <a href="/?facet=podcasts" class="nav-item px-4 py-1.5 rounded-full text-sm font-medium transition-colors <%= currentFacet === 'podcasts' ? 'bg-white text-black shadow-md' : 'bg-spotify-elevated hover:bg-spotify-elevated-hover text-white' %>">Podcasts</a>
      <a href="/?facet=playlists" class="nav-item px-4 py-1.5 rounded-full text-sm font-medium transition-colors <%= currentFacet === 'playlists' ? 'bg-white text-black shadow-md' : 'bg-spotify-elevated hover:bg-spotify-elevated-hover text-white' %>">Playlists</a>
    </div>

    <!-- Studio Promo Banner -->
    <% if (currentFacet === 'all') { %>
      <% if (user && (user.isArtist || user.isPodcaster)) { %>
        <div class="mb-10 grid gap-4 grid-cols-1 md:grid-cols-<%= (user.isArtist && user.isPodcaster) ? '2' : '1' %>">
          <% if (user.isArtist) { %>
            <div class="p-6 rounded-2xl bg-white/5 backdrop-blur-xl border border-white/10 flex items-center justify-between shadow-[0_8px_30px_rgba(0,0,0,0.3)] transition-transform duration-300 group hover:-translate-y-1">
              <div class="flex items-center gap-5 min-w-0">
                <div class="w-14 h-14 shrink-0 rounded-full flex items-center justify-center shadow-lg"
                     style="background: linear-gradient(135deg, #a259ff, #6600cc);">
                  <i class="ph ph-music-note text-white text-2xl"></i>
                </div>
                <div class="min-w-0">
                  <h2 class="text-white text-xl font-bold mb-1 truncate">Artist Studio</h2>
                  <p class="text-[#a7a7a7] text-sm truncate">Manage your artist profile and tracks.</p>
                </div>
              </div>
              <a href="/studio/artist" class="shrink-0 ml-4 px-6 py-2.5 bg-white text-black font-bold text-sm rounded-full hover:scale-105 transition-all shadow-md group-hover:shadow-[0_0_15px_rgba(255,255,255,0.4)]">
                Open
              </a>
            </div>
          <% } %>
          <% if (user.isPodcaster) { %>
            <div class="p-6 rounded-2xl bg-white/5 backdrop-blur-xl border border-white/10 flex items-center justify-between shadow-[0_8px_30px_rgba(0,0,0,0.3)] transition-transform duration-300 group hover:-translate-y-1">
              <div class="flex items-center gap-5 min-w-0">
                <div class="w-14 h-14 shrink-0 rounded-full flex items-center justify-center shadow-lg"
                     style="background: linear-gradient(135deg, #1ed760, #1aa34a);">
                  <i class="ph ph-microphone-stage text-black text-2xl"></i>
                </div>
                <div class="min-w-0">
                  <h2 class="text-white text-xl font-bold mb-1 truncate">Creator Studio</h2>
                  <p class="text-[#a7a7a7] text-sm truncate">Manage your podcasts and episodes.</p>
                </div>
              </div>
              <a href="/studio/creator" class="shrink-0 ml-4 px-6 py-2.5 bg-spotify-green text-black font-bold text-sm rounded-full hover:scale-105 hover:bg-spotify-green-hover transition-all shadow-md group-hover:shadow-[0_0_15px_rgba(29,185,84,0.4)]">
                Open
              </a>
            </div>
          <% } %>
        </div>
      <% } else if (user) { %>
        <div class="mb-10 p-6 rounded-2xl flex items-center justify-between shadow-[0_8px_30px_rgba(29,185,84,0.3)] transition-transform duration-300 group"
             style="background: linear-gradient(135deg, rgba(29,185,84,0.2) 0%, rgba(162,89,255,0.1) 100%); border: 1px solid rgba(255,255,255,0.1);">
          <div class="flex items-center gap-5">
            <div class="w-14 h-14 rounded-full flex items-center justify-center shadow-lg bg-black/40 backdrop-blur-md">
              <i class="ph ph-microphone-stage text-spotify-green text-3xl" ></i>
            </div>
            <div>
              <h2 class="text-white text-xl font-black tracking-tight mb-1">Share your voice with the world</h2>
              <p class="text-white/70 text-sm">Join Spotify for Creators to start a podcast or claim your artist profile today.</p>
            </div>
          </div>
          <a href="/studio" class="px-6 py-2.5 bg-spotify-green text-black font-bold text-sm rounded-full hover:scale-105 hover:bg-spotify-green-hover transition-all shadow-md group-hover:shadow-[0_0_15px_rgba(29,185,84,0.5)] shrink-0 ml-4">
            Get Started
          </a>
        </div>
      <% } %>
    <% } %>

    <!-- Section 0: Recently Played -->
    <% if (currentFacet === 'all' && typeof recentTracks !== 'undefined' && recentTracks.length > 0) { %>
      <section id="section-recently-played" class="mb-10">
        <h2 class="section-title mb-6 mt-4">Recently Played</h2>
        <div class="grid gap-4 grid-cols-2 md:grid-cols-4 lg:grid-cols-6 xl:grid-cols-8">
          <% recentTracks.forEach((track) => { %>
            <div class="bg-spotify-card hover:bg-spotify-card-hover p-4 rounded-md cursor-pointer transition-all duration-300 group relative flex flex-col" data-type="track" data-id="<%= track.id %>">
              <div class="w-full aspect-square bg-[#282828] rounded-md mb-4 shadow-lg overflow-hidden relative shrink-0">
                <% if (track.cover) { %>
                  <img src="<%= track.cover %>" class="w-full h-full object-cover">
                <% } else { %>
                  <div class="w-full h-full flex items-center justify-center">
                    <i class="ph ph-music-note text-gray-500 text-6xl"></i>
                  </div>
                <% } %>
                <button class="absolute bottom-2 right-2 btn-play translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 duration-300 z-10" onclick="event.preventDefault(); window.playTrack('<%= track.id %>', '<%= track.title.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= track.artist.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= track.cover %>', '<%= track.audio %>')">
                  <i class="ph-fill ph-play text-[24px] ml-[2px]" ></i>
                </button>
              </div>
              <h3 class="text-white font-bold mb-1 truncate text-sm"><%= track.title %></h3>
              <a href="/artist/<%= encodeURIComponent(track.artist) %>" class="text-xs text-spotify-subdued truncate hover:underline" onclick="event.stopPropagation()"><%= track.artist %></a>
              <button class="cm-trigger absolute top-2 right-2 text-spotify-subdued hover:text-white opacity-0 group-hover:opacity-100 transition-opacity z-20" onclick="event.preventDefault(); event.stopPropagation();">
                <i class="ph ph-dots-three text-[20px] bg-black/60 rounded-full p-1 backdrop-blur-md"></i>
              </button>
            </div>
          <% }) %>
        </div>
      </section>
    <% } %>

    <!-- Section 1: Recommended Playlists -->
    <% if (currentFacet === 'all' || currentFacet === 'playlists') { %>
      <section id="section-playlists" class="mb-10">
        <% if (currentFacet === 'all') { %>
        <div class="flex items-center justify-between mb-4">
          <a href="/?facet=playlists" class="nav-item section-title hover:underline">Recommended Playlists</a>
          <a href="/?facet=playlists" class="nav-item text-sm font-bold text-spotify-subdued hover:underline cursor-pointer">Show all</a>
        </div>
        <% } else { %>
        <h2 class="section-title mb-6 mt-4">All Playlists</h2>
        <% } %>
      <div class="grid gap-6 grid-cols-auto-fil-cards">
        <% if (typeof publicPlaylists !== 'undefined' && publicPlaylists.length > 0) { %>
          <% const displayPlaylists = currentFacet === 'all' ? publicPlaylists.slice(0, 5) : publicPlaylists; %>
          <% displayPlaylists.forEach((playlist) => { %>
            <a href="/playlist/<%= playlist.id %>" class="nav-item bg-spotify-card hover:bg-spotify-card-hover p-4 rounded-md cursor-pointer transition-all duration-300 group relative flex flex-col">
              <div class="w-full aspect-square bg-spotify-card-hover rounded-md mb-4 shadow-lg overflow-hidden relative shrink-0">
                <% if (playlist.cover) { %>
                  <img src="<%= playlist.cover %>" class="w-full h-full object-cover">
                <% } else { %>
                  <div class="w-full h-full flex items-center justify-center">
                    <i class="ph ph-music-note text-gray-500 text-6xl"></i>
                  </div>
                <% } %>
                <button class="absolute bottom-2 right-2 btn-play translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 duration-300 z-10" onclick="event.preventDefault(); window.location.href='/playlist/<%= playlist.id %>'">
                  <i class="ph-fill ph-play text-[24px] ml-[2px]" ></i>
                </button>
              </div>
              <h3 class="text-white font-bold mb-1 truncate"><%= playlist.title %></h3>
              <p class="text-sm text-spotify-subdued truncate">By <%= playlist.creator ? playlist.creator.name : 'Unknown' %></p>
            </a>
          <% }) %>
        <% } %>
      </div>
      </section>
    <% } %>

    <!-- Section 2: Recommended Artists -->
    <% if (currentFacet === 'all' || currentFacet === 'music' || currentFacet === 'music-artists') { %>
      <section id="section-artists" class="mb-10">
        <% if (currentFacet === 'all' || currentFacet === 'music') { %>
        <div class="flex items-center justify-between mb-4">
          <a href="/?facet=music-artists" class="nav-item section-title hover:underline">Recommended Artists</a>
          <a href="/?facet=music-artists" class="nav-item text-sm font-bold text-spotify-subdued hover:underline cursor-pointer">Show all</a>
        </div>
        <% } else { %>
        <h2 class="section-title mb-6 mt-4">Artists</h2>
        <% } %>
      <div class="grid gap-6 grid-cols-auto-fil-cards">
        <% if (typeof allArtists !== 'undefined' && allArtists.length > 0) { %>
          <% const displayArtists = currentFacet === 'all' ? allArtists.slice(0, 10) : allArtists; %>
          <% displayArtists.forEach((artist) => { %>
            <a href="/artist/<%= encodeURIComponent(artist.name) %>" class="nav-item bg-spotify-card hover:bg-spotify-card-hover p-4 rounded-md cursor-pointer transition-all duration-300 group relative flex flex-col">
              <div class="w-full aspect-square bg-spotify-card-hover rounded-full mb-4 shadow-lg overflow-hidden relative shrink-0">
                <% const artistImg = (artist.user && artist.user.avatar) ? artist.user.avatar : null; %>
                <% if (artistImg) { %>
                  <img src="<%= artistImg %>" class="w-full h-full object-cover">
                <% } else { %>
                  <div class="w-full h-full flex items-center justify-center">
                    <i class="ph ph-user text-gray-500 text-6xl"></i>
                  </div>
                <% } %>
                <button class="absolute bottom-2 right-2 btn-play translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 duration-300 z-10" onclick="event.preventDefault(); window.location.href='/artist/<%= encodeURIComponent(artist.name) %>'">
                  <i class="ph-fill ph-play text-[24px] ml-[2px]" ></i>
                </button>
              </div>
              <h3 class="text-white font-bold mb-1 truncate"><%= artist.name %></h3>
              <p class="text-sm text-spotify-subdued">Artist</p>
            </a>
          <% }) %>
        <% } %>
      </div>
      </section>
    <% } %>

    <!-- Section 3: Made For You -->
    <% if (currentFacet === 'all' || currentFacet === 'music' || currentFacet === 'music-songs') { %>
      <section id="section-music" class="mb-10">
        <% if (currentFacet === 'all' || currentFacet === 'music') { %>
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <a href="/?facet=music-songs" class="nav-item section-title hover:underline">Made For You</a>
            <% if (typeof recentTracks !== 'undefined' && recentTracks.length > 0) { %>
              <span class="text-xs font-semibold text-spotify-green bg-spotify-green/10 px-2 py-0.5 rounded-full uppercase tracking-wider">Personalized</span>
            <% } %>
          </div>
          <a href="/?facet=music-songs" class="nav-item text-sm font-bold text-spotify-subdued hover:underline cursor-pointer">Show all</a>
        </div>
        <% } else { %>
        <h2 class="section-title mb-6 mt-4">Made For You</h2>
        <% } %>
      <div class="grid gap-6 grid-cols-auto-fil-cards">
        <% const _recTracks = (typeof recommendedTracks !== 'undefined' && recommendedTracks.length > 0) ? recommendedTracks : (typeof allTracks !== 'undefined' ? allTracks : []); %>
        <% if (_recTracks.length > 0) { %>
          <% const displayTracks = currentFacet === 'all' ? _recTracks.slice(0, 10) : _recTracks; %>
          <% displayTracks.forEach((item) => { %>
            <div class="nav-item bg-spotify-card hover:bg-spotify-card-hover p-4 rounded-md cursor-pointer transition-all duration-300 group relative flex flex-col" data-type="track" data-id="<%= item.id %>">
              <div class="w-full aspect-square bg-spotify-card-hover rounded mb-4 shadow-lg overflow-hidden relative shrink-0">
                <% if (item.cover) { %>
                  <img src="<%= item.cover %>" class="w-full h-full object-cover">
                <% } else { %>
                  <div class="w-full h-full flex items-center justify-center">
                    <i class="ph ph-music-note text-gray-500 text-5xl"></i>
                  </div>
                <% } %>
                <button class="absolute bottom-2 right-2 btn-play translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 duration-300 z-10" onclick="event.preventDefault(); window.playTrack('<%= item.id %>', '<%= item.title.replace(/\x27/g, `\'`) %>', '<%= item.artist.replace(/\x27/g, `\'`) %>', '<%= item.cover %>', '<%= item.audio %>')">
                  <i class="ph-fill ph-play text-[24px] fill-current play-btn-icon" ></i>
                </button>
              </div>
              <h3 class="text-white font-bold mb-1 truncate"><%= item.title %></h3>
              <p class="text-sm text-spotify-subdued line-clamp-2"><%= item.artist %></p>
            </div>
          <% }) %>
        <% } else { %>
          <p class="text-spotify-subdued">No songs found.</p>
        <% } %>
      </div>
      </section>
    <% } %>

    <!-- Section 4: Recommended Podcasts -->
    <% if (currentFacet === 'all' || currentFacet === 'podcasts') { %>
      <section id="section-podcasts" class="mb-10">
        <% if (currentFacet === 'all') { %>
        <div class="flex items-center justify-between mb-4">
          <a href="/?facet=podcasts" class="nav-item section-title hover:underline">Recommended Podcasts</a>
          <a href="/?facet=podcasts" class="nav-item text-sm font-bold text-spotify-subdued hover:underline cursor-pointer">Show all</a>
        </div>
        <% } else { %>
        <h2 class="section-title mb-6 mt-4">All Podcasts</h2>
        <% } %>
      <div class="grid gap-6 grid-cols-auto-fil-cards">
        <% if (typeof allPodcasts !== 'undefined' && allPodcasts.length > 0) { %>
          <% const displayPodcasts = currentFacet === 'all' ? allPodcasts.slice(0, 10) : allPodcasts; %>
          <% displayPodcasts.forEach((item) => { %>
            <a href="/podcast/<%= item.id %>" class="nav-item bg-spotify-card hover:bg-spotify-card-hover p-4 rounded-md cursor-pointer transition-all duration-300 group relative flex flex-col">
              <div class="w-full aspect-square bg-spotify-card-hover rounded mb-4 shadow-lg overflow-hidden relative shrink-0">
                <% if (item.cover) { %>
                  <img src="<%= item.cover %>" class="w-full h-full object-cover">
                <% } else { %>
                  <div class="w-full h-full flex items-center justify-center">
                    <i class="ph ph-microphone text-gray-500 text-5xl"></i>
                  </div>
                <% } %>
                <% if (item.episodes && item.episodes.length > 0) { %>
                  <button class="absolute bottom-2 right-2 btn-play translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 duration-300 z-10" onclick="event.preventDefault(); window.playTrack('<%= item.episodes[0].id %>', '<%= item.episodes[0].title.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= item.title.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= item.cover %>', '<%= item.episodes[0].audio %>')">
                    <i class="ph-fill ph-play text-[24px] ml-[2px]" ></i>
                  </button>
                <% } %>
              </div>
              <h3 class="text-white font-bold mb-1 truncate"><%= item.title %></h3>
              <p class="text-sm text-spotify-subdued line-clamp-2"><%= (item.owner && item.owner.podcasterProfile) ? item.owner.podcasterProfile.name : (item.owner ? item.owner.name : 'Podcast') %></p>
            </a>
          <% }) %>
        <% } else { %>
          <p class="text-spotify-subdued">No podcasts found.</p>
        <% } %>
      </div>
      </section>
    <% } %>

  </div>
</div>
