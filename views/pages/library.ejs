<div class="page-content library-page">
  <section>
    <h2>Your Playlists</h2>
    <div class="card-grid">
      <% playlists.forEach(function(playlist) { %>
        <div class="card playlist-card" data-playlist-id="<%= playlist.id %>">
          <div class="cover-wrapper">
            <img src="https://picsum.photos/seed/<%= playlist.id %>/200/200" alt="<%= playlist.title %>">
            <button class="play-btn-overlay"><i class="fas fa-play"></i></button>
          </div>
          <h4><%= playlist.title %></h4>
          <p>By <%= playlist.creator %></p>
        </div>
      <% }); %>
    </div>
  </section>
</div>
