<div class="flex flex-col min-h-full w-full bg-spotify-black relative">
  <!-- Dynamic Gradient Background -->
  <div class="absolute top-0 left-0 w-full h-[400px] bg-gradient-to-b from-[#282828] to-[#121212] z-0 pointer-events-none"></div>

  <!-- Header Section -->
  <div class="relative z-10 flex flex-col justify-end px-8 pt-24 pb-8 min-h-[340px]">
    <div class="flex items-end gap-6">
      <!-- Podcast Cover -->
      <div style="width: 232px; height: 232px;" class="shadow-2xl overflow-hidden shrink-0 bg-spotify-card-hover rounded-xl flex items-center justify-center">
        <% if (podcastShow.cover) { %>
          <img src="<%= podcastShow.cover %>" class="w-full h-full object-cover">
        <% } else { %>
          <i class="ph ph-microphone-stage text-[#7f7f7f] text-[100px]"></i>
        <% } %>
      </div>
      
      <!-- Podcast Info -->
      <div class="flex flex-col gap-2">
        <span class="text-sm font-bold uppercase tracking-wider">Podcast</span>
        <h1 class="text-white font-bold leading-tight" style="font-size: clamp(32px, 5vw, 96px); letter-spacing: -0.04em;">
          <%= podcastShow.title %>
        </h1>
        <div class="flex items-center gap-2 mt-2">
          <% if (podcastShow.owner) { %>
            <span class="text-white font-bold text-sm"><%= (podcastShow.owner.podcasterProfile) ? podcastShow.owner.podcasterProfile.name : podcastShow.owner.name %></span>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="relative z-10 bg-black/20 p-8 flex-1">
    <div class="flex items-center gap-6 mb-8 px-6">
      <button class="btn-play-lg group"
        <% if (podcastShow.episodes && podcastShow.episodes.length > 0) { %>
          onclick="event.preventDefault(); window.playTrack('<%= podcastShow.episodes[0].id %>', '<%= podcastShow.episodes[0].title.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= podcastShow.title.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= podcastShow.cover %>', '<%= podcastShow.episodes[0].audio %>');"
        <% } %>
      >
        <i class="ph-fill ph-play text-[24px] ml-[2px]" ></i>
      </button>
      <button class="text-spotify-subdued hover:text-white transition-colors" 
              data-id="<%= podcastShow.id %>"
              data-title="<%= podcastShow.title %>"
              data-cover="<%= podcastShow.cover %>"
              data-owner="<%= podcastShow.owner ? (podcastShow.owner.podcasterProfile ? podcastShow.owner.podcasterProfile.name : podcastShow.owner.name) : 'Unknown' %>"
              title="Follow Podcast"
              onclick="window.toggleFollowPodcast(this)">
        <i class="<%= typeof isFollowing !== 'undefined' && isFollowing ? 'ph-fill ph-check-circle text-spotify-green' : 'ph ph-plus-circle' %> text-[36px]"></i>
      </button>
      <button class="text-spotify-subdued hover:text-white transition-colors" onclick="window.showToast('More options coming soon')">
        <i class="ph ph-dots-three text-[32px]"></i>
      </button>
    </div>

    <% if (podcastShow.description) { %>
      <div class="mb-8 max-w-[800px]">
        <h2 class="text-2xl font-bold mb-4">About</h2>
        <p class="text-spotify-subdued leading-relaxed"><%= podcastShow.description %></p>
      </div>
    <% } %>

    <h2 class="text-2xl font-bold mb-6">All Episodes</h2>
    
    <% if (podcastShow.episodes && podcastShow.episodes.length > 0) { %>
      <div class="flex flex-col gap-4">
        <% podcastShow.episodes.forEach((episode, index) => { %>
          <div class="group flex items-start gap-4 p-4 hover:bg-spotify-elevated rounded-xl cursor-pointer transition-colors mb-4 border border-transparent hover:border-white/10 relative">
            <div class="w-28 h-28 shrink-0 rounded-md overflow-hidden bg-spotify-card-hover">
              <img src="<%= podcastShow.cover %>" class="w-full h-full object-cover">
            </div>
            
            <div class="flex flex-col justify-center gap-2 flex-1 min-w-0">
              <a href="#" onclick="event.preventDefault(); window.playTrack('<%= episode.id %>', '<%= episode.title.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= podcastShow.title.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= podcastShow.cover %>', '<%= episode.audio %>');" class="text-white font-bold text-base hover:underline truncate block cursor-pointer">
                <%= episode.title %>
              </a>
              <p class="text-spotify-subdued text-sm line-clamp-2"><%= episode.description || 'No description available.' %></p>
              
              <div class="flex items-center gap-4 mt-2">
                <button onclick="event.preventDefault(); window.playTrack('<%= episode.id %>', '<%= episode.title.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= podcastShow.title.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= podcastShow.cover %>', '<%= episode.audio %>');" class="w-8 h-8 rounded-full bg-white hover:scale-105 transition-all flex items-center justify-center text-black shadow-lg">
                  <i class="ph-fill ph-play text-lg ml-0.5" ></i>
                </button>
                <span class="text-spotify-subdued text-sm font-semibold duration-display" data-audio-url="<%= episode.audio %>">
                  <% if (episode.duration_ms) { %>
                    <%= Math.floor(episode.duration_ms / 60000) %> min
                  <% } else { %>
                    ...
                  <% } %>
                </span>
                <% const isSavedEp = (typeof savedEpisodes !== 'undefined' && savedEpisodes.includes(episode.id)); %>
                <button class="text-spotify-subdued hover:text-white transition-colors ml-auto mr-4" title="Save to Your Episodes" data-id="<%= episode.id %>" onclick="window.toggleSaveEpisode(this)">
                  <i class="<%= isSavedEp ? 'ph-fill ph-check-circle text-spotify-green' : 'ph ph-plus-circle' %> text-[24px]"></i>
                </button>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-20 text-spotify-subdued">
        <i class="ph ph-microphone-stage text-5xl mb-4 opacity-50"></i>
        <p class="text-lg">No episodes yet.</p>
      </div>
    <% } %>
  </div>
</div>
