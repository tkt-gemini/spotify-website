<div class="flex flex-col min-h-full relative z-10 w-full bg-spotify-black overflow-x-hidden">
  <!-- Dynamic Cover Background -->
  <% const coverImg = (artistUser && artistUser.coverImage) ? artistUser.coverImage : null; %>
  <% if (coverImg) { %>
    <div class="absolute top-0 left-0 w-full h-[500px] z-0 pointer-events-none"
         style="background-image: url('<%= coverImg %>'); background-size: cover; background-position: center 20%; filter: brightness(0.6) saturate(1.2);">
      <!-- Smooth fade out gradient -->
      <div class="absolute inset-0 bg-gradient-to-t from-spotify-black via-spotify-black/60 to-transparent"></div>
    </div>
  <% } else { %>
    <!-- Fallback Gradient -->
    <div class="absolute top-0 left-0 w-full h-[400px] bg-gradient-to-b from-[#3b5998] to-[#121212] z-0 pointer-events-none transition-colors duration-500"></div>
  <% } %>

  <!-- Header Section -->
  <div class="relative z-10 flex flex-col justify-end px-8 pt-32 pb-6 min-h-[400px]">
    <div class="flex flex-col md:flex-row items-start md:items-end gap-6">
      <% const artistImg = (artistUser && artistUser.avatar) ? artistUser.avatar : ((artistUser && artistUser.user && artistUser.user.avatar) ? artistUser.user.avatar : null); %>
      <% if (artistImg) { %>
        <img src="<%= artistImg %>" class="w-48 h-48 md:w-56 md:h-56 rounded-full object-cover shadow-2xl shrink-0 border-4 border-black/20" alt="<%= artistUser ? artistUser.name : 'Artist' %>">
      <% } else { %>
        <div class="w-48 h-48 md:w-56 md:h-56 rounded-full bg-spotify-elevated flex items-center justify-center shadow-2xl shrink-0 border-4 border-black/20">
          <i class="ph ph-user text-gray-500 text-[80px]"></i>
        </div>
      <% } %>
      
      <div class="flex flex-col justify-end w-full">
        <div class="flex items-center gap-2 mb-2">
          <i class="ph-fill ph-seal-check text-[#3d91f4] text-[24px]" ></i>
          <span class="text-sm font-medium text-white shadow-sm">Verified Artist</span>
        </div>
        
        <h1 class="text-white font-black text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl leading-none tracking-tighter mb-6 drop-shadow-xl" style="word-break: break-word;">
          <%= artistUser ? artistUser.name : 'Unknown Artist' %>
        </h1>
        
        <div class="flex items-center text-sm font-medium text-white/90 gap-4">
          <span class="font-bold"><%= typeof followersCount !== 'undefined' ? followersCount.toLocaleString() : 0 %></span> followers
        </div>
      </div>
    </div>
  </div>

  <!-- Content Section -->
  <div class="relative z-10 bg-black/20 flex-1 px-8 pb-12">
    <div class="absolute top-0 left-0 w-full h-60 bg-gradient-to-b from-black/40 to-transparent z-[-1] pointer-events-none"></div>
    
    <!-- Action Row -->
    <div class="flex items-center gap-6 py-6 sticky top-0 z-20">
      <!-- We add a background div that fades in on scroll in a real app, but keep it simple here -->
      <button class="btn-play-lg group w-16 h-16 bg-spotify-green hover:bg-spotify-green-hover hover:scale-105 rounded-full flex items-center justify-center transition-all duration-300 shadow-xl"
              onclick="if(document.querySelector('.play-btn-icon')) { document.querySelector('.play-btn-icon').closest('button').click(); }">
        <i class="ph-fill ph-play text-black text-4xl ml-[2px]" ></i>
      </button>
      
      <button id="btn-follow-artist" data-name="<%= artistUser.name %>" data-avatar="<%= artistUser.avatar || (artistUser.user && artistUser.user.avatar) || '' %>" class="text-spotify-subdued hover:text-white transition-colors" title="Follow Artist" onclick="toggleFollowArtist(this)">
        <i class="<%= typeof isFollowing !== 'undefined' && isFollowing ? 'ph-fill ph-check-circle text-spotify-green' : 'ph ph-plus-circle' %> text-[36px]"></i>
      </button>
      
      <button class="text-spotify-subdued hover:text-white transition-colors active:scale-95" title="Copy Artist Link" onclick="window.copyToClipboard(window.location.href, 'Link copied to clipboard');">
        <i class="ph ph-dots-three text-[32px]"></i>
      </button>
    </div>

    <div class="flex flex-col lg:flex-row gap-10 mt-4">
      <!-- Popular Tracks -->
      <div class="flex-1 min-w-0">
        <h2 class="text-2xl font-bold text-white mb-6">Popular</h2>
        
        <div class="track-context-container flex flex-col gap-1" data-context-name="<%= typeof artistUser !== 'undefined' && artistUser ? artistUser.name : '' %>">
          <% if (typeof popularTracks !== 'undefined' && popularTracks.length > 0) { %>
            <% popularTracks.forEach((track, index) => { %>
              <div class="group flex items-center justify-between px-4 py-3 hover:bg-white/10 rounded-md cursor-pointer transition-colors text-sm text-spotify-subdued" data-type="track" data-id="<%= track.id %>">
                <div class="flex items-center gap-4 w-full" style="grid-template-columns: 32px 6fr 4fr minmax(120px, 1fr); display: grid;">
                  
                  <div class="w-8 flex items-center justify-center shrink-0 text-base">
                    <span class="group-hover:hidden"><%= index + 1 %></span>
                    <button class="hidden group-hover:flex items-center justify-center hover:scale-105" onclick="event.preventDefault(); window.playTrack('<%= track.id %>', '<%= track.title.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= track.artist.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= track.cover %>', '<%= track.audio %>')">
                      <i class="ph-fill ph-play text-[24px] fill-current text-white play-btn-icon" ></i>
                    </button>
                  </div>
                  
                  <div class="flex items-center gap-3 pr-2 min-w-0">
                    <div class="w-10 h-10 bg-spotify-card-hover shrink-0 rounded flex items-center justify-center overflow-hidden">
                      <% if (track.cover) { %>
                        <img src="<%= track.cover %>" class="w-full h-full object-cover">
                      <% } else { %>
                        <i class="ph ph-music-note text-gray-500"></i>
                      <% } %>
                    </div>
                    <span class="text-white font-medium truncate text-base group-hover:underline"><%= track.title %></span>
                  </div>
                  <div class="truncate pr-2 hover:text-white text-xs"><%= (track.playCount || 0).toLocaleString() %></div>
                  
                  <div class="flex items-center justify-end pr-4 gap-4 font-medium tracking-wide h-full">
                    <button class="btn-like-track text-spotify-subdued hover:text-white opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center h-full">
                      <i class="ph ph-heart text-[20px] leading-none"></i>
                    </button>
                    <span class="w-10 text-right duration-display flex items-center justify-end h-full" data-audio-url="<%= track.audio %>">--:--</span>
                    <button class="cm-trigger text-spotify-subdued hover:text-white opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center h-full">
                      <i class="ph ph-dots-three text-[20px] leading-none"></i>
                    </button>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <p class="text-gray-400 py-4">No popular tracks found.</p>
          <% } %>
        </div>
      </div>

      <!-- About Section / Artist Pick -->
      <div class="w-full lg:w-[350px] shrink-0">
        <h2 class="text-2xl font-bold text-white mb-6">About</h2>
        <div class="group relative bg-white/5 hover:bg-white/10 transition-colors rounded-2xl overflow-hidden cursor-pointer" onclick="document.getElementById('artist-bio-modal').classList.remove('hidden')">
          <% if (coverImg) { %>
            <div class="h-48 w-full">
              <img src="<%= coverImg %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="About Background">
            </div>
          <% } %>
          <div class="p-6 relative <%= coverImg ? '-mt-16 bg-gradient-to-t from-[#181818] via-[#181818] to-transparent pt-16' : '' %>">
            <div class="text-white font-bold mb-2">
              <span class="text-3xl"><%= typeof followersCount !== 'undefined' ? (followersCount >= 1000 ? (followersCount/1000).toFixed(1) + 'K' : followersCount) : 0 %></span> 
              <span class="text-spotify-subdued text-sm font-normal uppercase tracking-wider ml-1">Followers</span>
            </div>
            <p class="text-spotify-subdued text-sm font-medium line-clamp-3">
              <%= (artistUser && (artistUser.bio || artistUser.description)) ? (artistUser.bio || artistUser.description) : 'This creator has not added a bio yet.' %>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- About Modal -->
<div id="artist-bio-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm p-4" onclick="if(event.target===this) this.classList.add('hidden')">
  <div class="bg-[#282828] w-full max-w-2xl rounded-xl shadow-2xl overflow-hidden flex flex-col max-h-[80vh]">
    <div class="p-6 flex justify-between items-center border-b border-white/10">
      <h3 class="text-xl font-bold text-white">About</h3>
      <button class="text-spotify-subdued hover:text-white rounded-full bg-black/20 w-8 h-8 flex items-center justify-center transition-colors" onclick="document.getElementById('artist-bio-modal').classList.add('hidden')">
        <i class="ph ph-x text-[20px]"></i>
      </button>
    </div>
    <div class="p-6 overflow-y-auto">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-20 h-20 rounded-full overflow-hidden shrink-0">
          <img src="<%= artistImg || '/images/default-avatar.png' %>" class="w-full h-full object-cover" onerror="this.src='/images/default-avatar.png'">
        </div>
        <div>
          <h4 class="text-white font-bold text-xl"><%= artistUser ? artistUser.name : 'Unknown' %></h4>
          <span class="text-spotify-subdued font-medium"><%= typeof followersCount !== 'undefined' ? followersCount.toLocaleString() : 0 %> followers</span>
        </div>
      </div>
      <p class="text-white/90 text-sm leading-relaxed whitespace-pre-wrap"><%= (artistUser && (artistUser.bio || artistUser.description)) ? (artistUser.bio || artistUser.description) : 'This creator has not added a bio yet.' %></p>
    </div>
  </div>
</div>
