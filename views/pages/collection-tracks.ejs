<div class="flex flex-col min-h-full w-full bg-spotify-black relative overflow-x-hidden">
  <%- include('../partials/hero-header', {
    cover: null,
    icon: 'favorite',
    gradientFrom: '#5c20b8',
    gradientTo: '#121212',
    type: 'Playlist',
    title: 'Liked Songs',
    description: null,
    creator: typeof user !== 'undefined' && user ? { id: user.id, name: user.name, avatar: user.avatar } : { name: 'You' },
    metaText: `${tracks ? tracks.length : 0} songs`,
    isEditable: false
  }) %>

  <!-- Content Section -->
  <div class="relative z-10 bg-black/20 flex-1 px-8 pb-12 w-full">
    <div class="absolute top-0 left-0 w-full h-60 bg-gradient-to-b from-black/40 to-transparent z-[-1] pointer-events-none"></div>

    <div class="flex items-center gap-6 py-6 w-full sticky top-0 z-20">
      <% if (tracks && tracks.length > 0) { %>
      <button class="btn-play-lg group w-14 h-14 bg-spotify-green hover:bg-spotify-green-hover hover:scale-105 rounded-full flex items-center justify-center transition-all duration-300 shadow-xl"
              onclick="if(document.querySelector('.play-btn-icon')) { document.querySelector('.play-btn-icon').closest('button').click(); }">
        <i class="ph-fill ph-play text-black text-2xl ml-[2px]" ></i>
      </button>
      <% } else { %>
      <button class="w-14 h-14 bg-white/10 text-white/40 rounded-full flex items-center justify-center cursor-not-allowed border border-white/5">
        <i class="ph-fill ph-play text-2xl ml-[2px]" ></i>
      </button>
      <% } %>
    </div>

    <!-- Tracklist Table -->
    <%- include('../partials/track-list', {
      tracks: tracks ? tracks : [],
      contextName: 'Liked Songs',
      playlistId: null,
      showAlbum: true,
      showDateAdded: true,
      libraryItems: typeof libraryItems !== 'undefined' ? libraryItems : null
    }) %>

  </div>
</div>
