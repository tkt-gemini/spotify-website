<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Spotify - Sign up</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
</head>
<body class="bg-black flex flex-col items-center justify-center min-h-screen font-sans text-white">
  
  <div class="w-full max-w-[734px] bg-spotify-black rounded-lg p-10 sm:p-20 shadow-2xl flex flex-col items-center">
    <div class="mb-10">
      <i class="ph ph-music-note text-[64px] text-white"></i>
    </div>
    <h1 class="text-3xl font-bold mb-10 text-center tracking-tighter">Sign up to start listening</h1>
    
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="w-full max-w-[324px] bg-[#e91429] text-white text-sm font-bold px-4 py-3 rounded mb-6 flex gap-2 items-center">
        <i class="ph ph-warning-circle text-[20px]"></i>
        <span><%= error %></span>
      </div>
    <% } %>

    <form action="/auth/register" method="POST" class="w-full max-w-[324px] flex flex-col gap-4">
      <div class="flex flex-col gap-2">
        <label for="name" class="text-sm font-bold">What should we call you?</label>
        <input type="text" id="name" name="name" class="w-full bg-spotify-black border border-[#727272] rounded focus:border-white focus:outline-none focus:ring-1 focus:ring-white px-3 py-3 text-base placeholder-gray-400 hover:border-white transition-colors" placeholder="Enter a profile name" required>
        <span class="text-xs text-spotify-subdued">This appears on your profile.</span>
      </div>

      <div class="flex flex-col gap-2 mt-2">
        <label for="username" class="text-sm font-bold">Email address</label>
        <input type="text" id="username" name="username" class="w-full bg-spotify-black border border-[#727272] rounded focus:border-white focus:outline-none focus:ring-1 focus:ring-white px-3 py-3 text-base placeholder-gray-400 hover:border-white transition-colors" placeholder="name@domain.com" required>
      </div>
      
      <div class="flex flex-col gap-2 mt-2">
        <label for="password" class="text-sm font-bold">Create a password</label>
        <input type="password" id="password" name="password" class="w-full bg-spotify-black border border-[#727272] rounded focus:border-white focus:outline-none focus:ring-1 focus:ring-white px-3 py-3 text-base placeholder-gray-400 hover:border-white transition-colors" required>
      </div>
      
      <button type="submit" class="w-full bg-spotify-green hover:bg-spotify-green-hover text-black font-bold rounded-full px-8 py-3.5 mt-8 transition-transform hover:scale-105 active:scale-100">
        Sign Up
      </button>
    </form>
    
    <div class="w-full max-w-[324px] h-[1px] bg-spotify-card-hover my-8"></div>
    
    <p class="text-spotify-subdued text-sm font-medium">Already have an account? <a href="/auth/login" class="text-white hover:text-spotify-green underline hover:no-underline">Log in here</a>.</p>
  </div>
</body>
</html>
