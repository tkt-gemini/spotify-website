<div class="flex flex-col min-h-full w-full bg-spotify-base">
  <div class="p-8">
    <div class="flex items-center gap-3 mb-8">
      <i class="ph-fill ph-shield-check text-[#e2b83a] text-4xl"></i>
      <h1 class="text-white text-3xl font-bold">Admin Dashboard</h1>
    </div>

    <!-- Stats Section -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
      <div class="bg-spotify-elevated rounded-lg p-6 shadow-md border border-white/5">
        <h3 class="text-spotify-subdued text-sm font-bold uppercase tracking-wider mb-2">Total Users</h3>
        <p class="text-white text-4xl font-bold" id="admin-stat-users">-</p>
      </div>
      <div class="bg-spotify-elevated rounded-lg p-6 shadow-md border border-white/5">
        <h3 class="text-spotify-subdued text-sm font-bold uppercase tracking-wider mb-2">Total Tracks</h3>
        <p class="text-white text-4xl font-bold" id="admin-stat-tracks">-</p>
      </div>
      <div class="bg-spotify-elevated rounded-lg p-6 shadow-md border border-white/5">
        <h3 class="text-spotify-subdued text-sm font-bold uppercase tracking-wider mb-2">Total Playlists</h3>
        <p class="text-white text-4xl font-bold" id="admin-stat-playlists">-</p>
      </div>
    </div>

    <!-- Tabs -->
    <div class="flex items-center gap-6 border-b border-white/10 mb-6">
      <button class="admin-tab-btn px-4 py-3 text-white font-bold border-b-2 border-spotify-green transition-colors" data-tab="users">Users</button>
      <button class="admin-tab-btn px-4 py-3 text-spotify-subdued hover:text-white font-bold border-b-2 border-transparent transition-colors" data-tab="tracks">Tracks</button>
    </div>

    <!-- Users Tab -->
    <div id="admin-tab-users" class="admin-tab-content">
      <div class="bg-spotify-elevated rounded-lg overflow-hidden border border-white/5">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="border-b border-white/10 text-spotify-subdued text-sm font-medium">
                <th class="p-4">ID</th>
                <th class="p-4">Username</th>
                <th class="p-4">Email</th>
                <th class="p-4">Admin</th>
                <th class="p-4">Artist</th>
                <th class="p-4">Podcaster</th>
                <th class="p-4">Actions</th>
              </tr>
            </thead>
            <tbody id="admin-users-tbody" class="text-sm">
              <tr><td colspan="7" class="p-4 text-center text-spotify-subdued">Loading users...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Tracks Tab -->
    <div id="admin-tab-tracks" class="admin-tab-content hidden">
      <div class="bg-spotify-elevated rounded-lg overflow-hidden border border-white/5">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="border-b border-white/10 text-spotify-subdued text-sm font-medium">
                <th class="p-4">ID</th>
                <th class="p-4">Title</th>
                <th class="p-4">Artist</th>
                <th class="p-4">Type</th>
                <th class="p-4">Plays</th>
                <th class="p-4">Actions</th>
              </tr>
            </thead>
            <tbody id="admin-tracks-tbody" class="text-sm">
              <tr><td colspan="6" class="p-4 text-center text-spotify-subdued">Loading tracks...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</div>

<script src="/js/modules/admin.js"></script>
