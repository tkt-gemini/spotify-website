<%# Studio Hub Page — /studio %>
<div class="flex flex-col min-h-full w-full bg-spotify-black">

  <%# ── Hero Header ──────────────────────────────────────────────────────── %>
  <div class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#1a1a2e] via-[#16213e] to-[#0f3460] opacity-90"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 20% 50%, rgba(29,185,84,0.15) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(138,43,226,0.1) 0%, transparent 50%);"></div>
    <div class="relative z-10 px-8 pt-24 pb-12">
      <p class="text-spotify-green text-sm font-bold uppercase tracking-[0.2em] mb-3">Your Studio</p>
      <h1 class="text-white text-5xl font-black tracking-tighter mb-4">Create &amp; Manage</h1>
      <p class="text-[#a7a7a7] text-lg max-w-lg">One place to manage your artist profile and your podcast shows.</p>
    </div>
  </div>

  <%# ── Role Cards ───────────────────────────────────────────────────────── %>
  <div class="px-8 py-10 flex flex-col gap-6 flex-1">

    <%# ── ARTIST STUDIO CARD ──────────────────────────────────────────────── %>
    <div class="group relative rounded-3xl overflow-hidden bg-white/5 backdrop-blur-xl border border-white/10 hover:border-white/20 transition-all duration-500 hover:shadow-[0_8px_30px_rgba(162,89,255,0.2)] cursor-pointer"
         onclick="<%= overview.isArtist ? `window.location.href='/studio/artist'` : `window.studioRegisterArtist()` %>">
      <div class="absolute inset-0 bg-gradient-to-r from-[#a259ff]/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      <div class="relative flex items-center gap-6 p-6">
        <%# Icon %>
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center shrink-0 shadow-[0_0_20px_rgba(162,89,255,0.4)] group-hover:shadow-[0_0_30px_rgba(162,89,255,0.6)] transition-shadow duration-500"
             style="background: linear-gradient(135deg, #a259ff, #6600cc);">
          <i class="ph ph-music-note text-white text-3xl" ></i>
        </div>

        <%# Info %>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <h2 class="text-white font-black text-xl">Artist Studio</h2>
            <% if (overview.isArtist) { %>
              <span class="text-[10px] font-bold uppercase tracking-widest bg-[#a259ff]/20 text-[#a259ff] px-2 py-0.5 rounded-full border border-[#a259ff]/30">Active</span>
            <% } %>
          </div>
          <p class="text-[#a7a7a7] text-sm">
            <% if (overview.isArtist && overview.artistProfile) { %>
              Manage your profile as <span class="text-white font-semibold"><%= overview.artistProfile.name %></span>.
              <% if (overview.artistTracks && overview.artistTracks.length > 0) { %>
                <%= overview.artistTracks.length %> track<%= overview.artistTracks.length !== 1 ? 's' : '' %>.
              <% } %>
            <% } else { %>
              Manage your public artist profile, bio, and images.
            <% } %>
          </p>
        </div>

        <%# CTA %>
        <div class="shrink-0">
          <% if (overview.isArtist) { %>
            <div class="flex items-center gap-2 text-[#a259ff] font-bold text-sm">
              <span>Manage</span>
              <i class="ph ph-caret-right text-lg"></i>
            </div>
          <% } else { %>
            <button id="studio-register-artist-btn"
              class="px-6 py-2.5 rounded-full font-bold text-sm text-white border border-[#a259ff] hover:bg-[#a259ff] hover:shadow-[0_0_15px_rgba(162,89,255,0.5)] transition-all duration-300"
              onclick="event.stopPropagation(); window.studioRegisterArtist()">
              Get Started
            </button>
          <% } %>
        </div>
      </div>
    </div>

    <%# ── CREATOR STUDIO CARD ────────────────────────────────────────────── %>
    <div class="group relative rounded-3xl overflow-hidden bg-white/5 backdrop-blur-xl border border-white/10 hover:border-white/20 transition-all duration-500 hover:shadow-[0_8px_30px_rgba(29,185,84,0.2)] cursor-pointer"
         onclick="<%= overview.isPodcaster ? `window.location.href='/studio/creator'` : `window.studioRegisterPodcaster()` %>">
      <div class="absolute inset-0 bg-gradient-to-r from-spotify-green/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      <div class="relative flex items-center gap-6 p-6">
        <%# Icon %>
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center shrink-0 shadow-[0_0_20px_rgba(29,185,84,0.4)] group-hover:shadow-[0_0_30px_rgba(29,185,84,0.6)] transition-shadow duration-500"
             style="background: linear-gradient(135deg, #1ed760, #1aa34a);">
          <i class="ph ph-microphone-stage text-black text-3xl" ></i>
        </div>

        <%# Info %>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <h2 class="text-white font-black text-xl">Creator Studio</h2>
            <% if (overview.isPodcaster) { %>
              <span class="text-[10px] font-bold uppercase tracking-widest bg-spotify-green/20 text-spotify-green px-2 py-0.5 rounded-full border border-spotify-green/30">Active</span>
            <% } %>
          </div>
          <p class="text-[#a7a7a7] text-sm">
            <% if (overview.isPodcaster) { %>
              <% const showCount = overview.podcastShows ? overview.podcastShows.length : 0; %>
              <% if (showCount > 0) { %>
                <%= showCount %> podcast show<%= showCount !== 1 ? 's' : '' %>.
              <% } else { %>
                You're a creator! Start your first podcast show.
              <% } %>
            <% } else { %>
              Create and manage podcast shows, upload episodes, track analytics.
            <% } %>
          </p>
        </div>

        <%# CTA %>
        <div class="shrink-0">
          <% if (overview.isPodcaster) { %>
            <div class="flex items-center gap-2 text-spotify-green font-bold text-sm">
              <span>Manage</span>
              <i class="ph ph-caret-right text-lg"></i>
            </div>
          <% } else { %>
            <button id="studio-register-podcaster-btn"
              class="px-6 py-2.5 rounded-full font-bold text-sm text-black bg-spotify-green hover:bg-spotify-green-hover hover:shadow-[0_0_15px_rgba(29,185,84,0.5)] transition-all duration-300"
              onclick="event.stopPropagation(); window.studioRegisterPodcaster()">
              Start Podcasting
            </button>
          <% } %>
        </div>
      </div>

      <%# Shows preview strip (if podcaster + has shows) %>
      <% if (overview.isPodcaster && overview.podcastShows && overview.podcastShows.length > 0) { %>
        <div class="border-t border-white/5 px-6 py-4">
          <div class="flex gap-3 overflow-x-auto pb-1 no-scrollbar">
            <% overview.podcastShows.slice(0, 5).forEach(show => { %>
              <a href="/studio/creator/show/<%= show.id %>"
                 class="shrink-0 flex items-center gap-3 bg-white/5 hover:bg-white/10 px-3 py-2 rounded-xl transition-colors"
                 onclick="event.stopPropagation()">
                <div class="w-8 h-8 rounded-lg bg-[#282828] overflow-hidden shrink-0">
                  <% if (show.cover) { %>
                    <img src="<%= show.cover %>" class="w-full h-full object-cover" alt="<%= show.title %>">
                  <% } else { %>
                    <div class="w-full h-full flex items-center justify-center">
                      <i class="ph ph-microphone-stage text-[#727272] text-sm"></i>
                    </div>
                  <% } %>
                </div>
                <span class="text-white text-xs font-semibold truncate max-w-[120px]"><%= show.title %></span>
              </a>
            <% }) %>
          </div>
        </div>
      <% } %>
    </div>

    <%# ── Tips section ───────────────────────────────────────────────────── %>
    <div class="mt-4 p-5 rounded-xl bg-white/5 backdrop-blur-md border border-white/10 shadow-lg">
      <p class="text-[#a7a7a7] text-xs leading-relaxed">
        <i class="ph ph-info text-spotify-green text-sm align-middle mr-1" ></i>
        You can be both an Artist and a Creator — each role is managed separately. Changes to your artist profile appear on your public artist page, while podcast shows are visible on the podcast pages.
      </p>
    </div>

  </div>
</div>
