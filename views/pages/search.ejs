<div class="flex flex-col h-full w-full bg-spotify-black px-6 pt-24 pb-8">
  <% if (typeof q !== 'undefined' && q.trim().length > 0) { %>
    <!-- Search Results View -->
    <div class="mb-6 flex items-center justify-between">
      <h2 class="text-2xl font-bold text-white">Search results for "<%= q %>"</h2>
    </div>
    
    <div class="flex flex-col gap-10">
      <% if (searchResults.artists.length === 0 && searchResults.tracks.length === 0 && searchResults.playlists.length === 0 && (!searchResults.podcasts || searchResults.podcasts.length === 0)) { %>
        <div class="text-spotify-subdued text-sm">
          <p>No results found for <strong><%= q %></strong>.</p>
          <p>Please make sure your words are spelled correctly or use less or different keywords.</p>
        </div>
      <% } else { %>

        <!-- Artists Section -->
        <% if (searchResults.artists.length > 0) { %>
          <section>
            <h3 class="text-xl font-bold text-white mb-4">Artists</h3>
            <div class="grid gap-6 grid-cols-auto-fil-cards">
              <% searchResults.artists.forEach((artist) => { %>
                <a href="/artist/<%= encodeURIComponent(artist.name) %>" class="nav-item bg-spotify-card hover:bg-spotify-card-hover p-4 rounded-md cursor-pointer transition-all duration-300 group relative flex flex-col">
                  <div class="w-full aspect-square bg-spotify-card-hover rounded-full mb-4 shadow-lg overflow-hidden relative shrink-0">
                    <% const artistImg = (artist.user && artist.user.avatar) ? artist.user.avatar : null; %>
                    <% if (artistImg) { %>
                      <img src="<%= artistImg %>" class="w-full h-full object-cover">
                    <% } else { %>
                      <div class="w-full h-full flex items-center justify-center">
                        <i class="ph ph-user text-gray-500 text-6xl"></i>
                      </div>
                    <% } %>
                    <button class="absolute bottom-2 right-2 btn-play translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 duration-300 z-10" onclick="event.preventDefault(); window.location.href='/artist/<%= encodeURIComponent(artist.name) %>'">
                      <i class="ph-fill ph-play text-[24px] ml-[2px]" ></i>
                    </button>
                  </div>
                  <h3 class="text-white font-bold mb-1 truncate"><%= artist.name %></h3>
                  <p class="text-sm text-spotify-subdued">Artist</p>
                </a>
              <% }) %>
            </div>
          </section>
        <% } %>
        
        <!-- Songs Section -->
        <% if (searchResults.tracks.length > 0) { %>
          <section>
            <h3 class="text-xl font-bold text-white mb-4">Songs</h3>
            <div class="grid gap-6 grid-cols-auto-fil-cards">
              <% searchResults.tracks.forEach((item) => { %>
                <div class="nav-item bg-spotify-card hover:bg-spotify-card-hover p-4 rounded-md cursor-pointer transition-all duration-300 group relative flex flex-col" data-type="track" data-id="<%= item.id %>">
                  <div class="w-full aspect-square bg-spotify-card-hover rounded mb-4 shadow-lg overflow-hidden relative shrink-0">
                    <% if (item.cover) { %>
                      <img src="<%= item.cover %>" class="w-full h-full object-cover">
                    <% } else { %>
                      <div class="w-full h-full flex items-center justify-center">
                        <i class="ph ph-music-note text-gray-500 text-5xl"></i>
                      </div>
                    <% } %>
                    <button class="absolute bottom-2 right-2 btn-play translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 duration-300 z-10" onclick="event.preventDefault(); window.playTrack('<%= item.id %>', '<%= item.title.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= item.artist.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= item.cover %>', '<%= item.audio %>')">
                      <i class="ph-fill ph-play text-[24px] fill-current play-btn-icon" ></i>
                    </button>
                    <!-- Context Menu Trigger for Track Card -->
                    <button class="cm-trigger absolute top-2 right-2 text-white/70 hover:text-white opacity-0 group-hover:opacity-100 transition-opacity bg-black/40 hover:bg-black/80 rounded-full w-8 h-8 flex items-center justify-center z-10">
                      <i class="ph ph-dots-three text-[20px] pointer-events-none"></i>
                    </button>
                  </div>
                  <h3 class="text-white font-bold mb-1 truncate"><%= item.title %></h3>
                  <p class="text-sm text-spotify-subdued line-clamp-2"><%= item.artist %></p>
                </div>
              <% }) %>
            </div>
          </section>
        <% } %>
        
        <!-- Playlists Section -->
        <% if (searchResults.playlists.length > 0) { %>
          <section>
            <h3 class="text-xl font-bold text-white mb-4">Playlists</h3>
            <div class="grid gap-6 grid-cols-auto-fil-cards">
              <% searchResults.playlists.forEach(playlist => { %>
                <a href="/playlist/<%= playlist.id %>" class="nav-item bg-spotify-card hover:bg-spotify-card-hover p-4 rounded-md cursor-pointer transition-all duration-300 group relative flex flex-col">
                  <div class="w-full aspect-square bg-spotify-card-hover rounded mb-4 shadow-lg overflow-hidden relative shrink-0">
                    <% if (playlist.cover) { %>
                      <img src="<%= playlist.cover %>" class="w-full h-full object-cover">
                    <% } else { %>
                      <div class="w-full h-full flex items-center justify-center">
                        <i class="ph ph-music-note text-gray-500 text-5xl"></i>
                      </div>
                    <% } %>
                    <button class="absolute bottom-2 right-2 btn-play translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 duration-300 z-10" onclick="event.preventDefault(); window.location.href='/playlist/<%= playlist.id %>'">
                      <i class="ph-fill ph-play text-[24px] fill-current play-btn-icon" ></i>
                    </button>
                  </div>
                  <h3 class="text-white font-bold mb-1 truncate"><%= playlist.title %></h3>
                  <p class="text-sm text-spotify-subdued line-clamp-2">By <%= playlist.creator ? playlist.creator.name : 'Unknown' %></p>
                </a>
              <% }) %>
            </div>
          </section>
        <% } %>

        <!-- Podcasts Section -->
        <% if (searchResults.podcasts && searchResults.podcasts.length > 0) { %>
          <section>
            <h3 class="text-xl font-bold text-white mb-4">Podcasts & Shows</h3>
            <div class="grid gap-6 grid-cols-auto-fil-cards">
              <% searchResults.podcasts.forEach(podcast => { %>
                <a href="/podcast/<%= podcast.id %>" class="nav-item bg-spotify-card hover:bg-spotify-card-hover p-4 rounded-md cursor-pointer transition-all duration-300 group relative flex flex-col">
                  <div class="w-full aspect-square bg-spotify-card-hover rounded mb-4 shadow-lg overflow-hidden relative shrink-0">
                    <% if (podcast.cover) { %>
                      <img src="<%= podcast.cover %>" class="w-full h-full object-cover">
                    <% } else { %>
                      <div class="w-full h-full flex items-center justify-center">
                        <i class="ph ph-microphone text-gray-500 text-5xl"></i>
                      </div>
                    <% } %>
                    <% if (podcast.episodes && podcast.episodes.length > 0) { %>
                      <button class="absolute bottom-2 right-2 btn-play translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 duration-300 z-10" onclick="event.preventDefault(); window.playTrack('<%= podcast.episodes[0].id %>', '<%= podcast.episodes[0].title.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= podcast.title.replace(/\\x27/g, `\\\\\\x27`) %>', '<%= podcast.cover %>', '<%= podcast.episodes[0].audio %>')">
                        <i class="ph-fill ph-play text-[24px] ml-[2px]" ></i>
                      </button>
                    <% } %>
                  </div>
                  <h3 class="text-white font-bold mb-1 truncate"><%= podcast.title %></h3>
                  <p class="text-sm text-spotify-subdued line-clamp-2">By <%= (podcast.owner && podcast.owner.podcasterProfile) ? podcast.owner.podcasterProfile.name : (podcast.owner ? podcast.owner.name : 'Unknown') %></p>
                </a>
              <% }) %>
            </div>
          </section>
        <% } %>
      <% } %>
    </div>
    
  <% } else { %>
    <!-- Browse All View -->
    <div class="flex flex-col items-center justify-center h-[50vh] text-center text-spotify-subdued">
      <i class="ph ph-magnifying-glass text-[64px] mb-4"></i>
      <h2 class="text-2xl font-bold text-white mb-2">Search Spotify</h2>
      <p>Find your favorite songs, artists, podcasts, and more.</p>
    </div>
  <% } %>
</div>
